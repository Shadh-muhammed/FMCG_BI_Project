	measure 'Promo Bar Chart Card' =
			
			VAR ChartH = 42
			VAR BarW = 14
			VAR BarGap = 2
			VAR GroupW = 55
			VAR StartX = 15
			VAR Categories = VALUES(Dim_Product[category])
			VAR MaxVal =
			    MAXX(
			        Categories,
			        MAX(CALCULATE([Baseline Sales]), CALCULATE([Promoted Sales]))
			    )
			VAR Bars =
			    CONCATENATEX(
			        Categories,
			        VAR CatRank = RANKX(ALL(Dim_Product[category]), Dim_Product[category], , ASC, Dense) - 1
			        VAR XPos = StartX + CatRank * GroupW
			        VAR Baseline = CALCULATE([Baseline Sales])
			        VAR Promoted = CALCULATE([Promoted Sales])
			        VAR BaseH = DIVIDE(Baseline, MaxVal) * ChartH
			        VAR PromH = DIVIDE(Promoted, MaxVal) * ChartH
			        RETURN
			        "<rect x='" & XPos & "' y='" & FORMAT(100 - BaseH, "0.0") & "' width='" & BarW & "' height='" & FORMAT(BaseH, "0.0") & "' fill='#cfe4d6'/>" &
			        "<rect x='" & (XPos + BarW + BarGap) & "' y='" & FORMAT(100 - PromH, "0.0") & "' width='" & BarW & "' height='" & FORMAT(PromH, "0.0") & "' fill='#1f6b45'/>" &
			        "<text x='" & (XPos + BarW) & "' y='112' text-anchor='middle' font-size='8' fill='#3f7a53'>" & Dim_Product[category] & "</text>",
			        "",
			        RANKX(ALL(Dim_Product[category]), Dim_Product[category], , ASC, Dense), ASC
			    )
			VAR WeakestCat =
			    MINX(
			        TOPN(1, Categories, CALCULATE([Promo Lift %]), ASC),
			        Dim_Product[category]
			    )
			VAR WeakestLift = CALCULATE([Promo Lift %], Dim_Product[category] = WeakestCat)
			VAR InsightText =
			    WeakestCat & " category shows the weakest incremental lift at " &
			    FORMAT(WeakestLift, "0.0%") &
			    " — promoted volume barely clears baseline, signalling promo fatigue."
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:14px;font-family:sans-serif'>" &
			"<div style='font-size:12px;font-weight:600;color:#1a1a1a;margin-bottom:2px'>Baseline vs promoted units &middot; by category</div>" &
			"<div style='font-size:10px;color:#9a9a92;margin-bottom:10px'>Avg units sold</div>" &
			"<svg viewBox='0 0 300 105' xmlns='http://www.w3.org/2000/svg'>"  &
			Bars &
			"<g transform='translate(245,8)'>" &
			"<rect width='6' height='6' fill='#cfe4d6'/><text x='9' y='6' font-size='6.5' fill='#3f7a53'>baseline</text>" &
			"<rect y='11' width='6' height='6' fill='#1f6b45'/><text x='9' y='17' font-size='6.5' fill='#1f6b45'>promoted</text>" &
			"</g></svg>" &
			"<div style='background:#fbe4e4;border-radius:4px;padding:8px 10px;margin-top:4px;font-size:10.5px;color:#8a2f2f;line-height:1.5'>&#10022; " &
			InsightText &
			"</div>" &
			"</div>"
		lineageTag: 9a0aaf00-5f21-4eb8-adeb-be082d09e244

	measure 'Promo Scatter Card' =
			
			VAR PlotW = 260
			VAR PlotH = 82
			VAR OriginX = 30
			VAR OriginY = 8
			VAR SKUs = VALUES(Dim_Product[sku])
			VAR LiftThreshold = 0.05
			VAR FreqThreshold =
			    PERCENTILEX.INC(SKUs, CALCULATE([Promo Frequency %]), 0.5)
			VAR MinFreq = MINX(SKUs, CALCULATE([Promo Frequency %]))
			VAR MaxFreq = MAXX(SKUs, CALCULATE([Promo Frequency %]))
			VAR MinLift = MINX(SKUs, CALCULATE([Promo Lift %]))
			VAR MaxLift = MAXX(SKUs, CALCULATE([Promo Lift %]))
			VAR FreqRange = MaxFreq - MinFreq
			VAR LiftRange = MaxLift - MinLift
			VAR ZeroY = OriginY + PlotH - DIVIDE(0 - MinLift, LiftRange) * PlotH
			VAR Points =
			    CONCATENATEX(
			        SKUs,
			        VAR Freq = CALCULATE([Promo Frequency %])
			        VAR Lift = CALCULATE([Promo Lift %])
			        VAR CX = OriginX + DIVIDE(Freq - MinFreq, FreqRange) * PlotW
			        VAR CY = OriginY + PlotH - DIVIDE(Lift - MinLift, LiftRange) * PlotH
			        VAR Color =
			            SWITCH(
			                TRUE(),
			                Freq >= FreqThreshold && Lift >= LiftThreshold, "#1f6b45",
			                Freq >= FreqThreshold && Lift < LiftThreshold, "#c0392b",
			                "#c9932e"
			            )
			        RETURN
			        "<circle cx='" & FORMAT(CX, "0.0") & "' cy='" & FORMAT(CY, "0.0") & "' r='4.5' fill='" & Color & "'/>",
			        ""
			    )
			VAR RiskCount =
			    COUNTX(
			        FILTER(SKUs, CALCULATE([Promo Frequency %]) >= FreqThreshold && CALCULATE([Promo Lift %]) < LiftThreshold),
			        Dim_Product[sku]
			    )
			VAR RiskSpend =
			    SUMX(
			        FILTER(SKUs, CALCULATE([Promo Frequency %]) >= FreqThreshold && CALCULATE([Promo Lift %]) < LiftThreshold),
			        CALCULATE(SUMX('Fact', Fact[units_sold] * Fact[price_unit]), Fact[promotion_flag] = 1)
			    )
			VAR InsightText =
			    RiskCount & " SKUs sit high-frequency, low-lift — repeated discounting with no incremental gain, ~AED " &
			    FORMAT(RiskSpend / 1000000, "0.0") & "M trade spend at risk."
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:14px;font-family:sans-serif'>" &
			"<div style='font-size:12px;font-weight:600;color:#1a1a1a;margin-bottom:2px'>Promo frequency vs promo lift &middot; by SKU</div>" &
			"<div style='font-size:10px;color:#9a9a92;margin-bottom:10px'>Bottom right = discount dependency</div>" &
			"<svg viewBox='0 0 300 100' xmlns='http://www.w3.org/2000/svg'>" &
			"<line x1='" & OriginX & "' y1='" & OriginY & "' x2='" & OriginX & "' y2='90' stroke='#e2e0d8' stroke-width='1'/>" &
			"<line x1='" & OriginX & "' y1='" & FORMAT(ZeroY, "0.0") & "' x2='290' y2='" & FORMAT(ZeroY, "0.0") & "' stroke='#e2e0d8' stroke-width='1'/>" &
			"<text x='288' y='" & FORMAT(ZeroY - 6, "0.0") & "' text-anchor='end' font-size='7.5' fill='#1f6b45'>good investment</text>" &
			"<text x='288' y='" & FORMAT(ZeroY + 12, "0.0") & "' text-anchor='end' font-size='7.5' fill='#b23b3b'>discount dependency</text>" &
			Points &
			"</svg>" &
			"<div style='background:#fbe4e4;border-radius:4px;padding:8px 10px;margin-top:8px;font-size:10.5px;color:#8a2f2f;line-height:1.5'>&#10022; " &
			InsightText &
			"</div>" &
			"</div>"
		lineageTag: ad17ef96-5b26-4e63-bb8f-ddd60171de62

	measure 'Stock Risk Scatter Card' =
			
			VAR PlotW = 260
			VAR PlotH = 82
			VAR OriginX = 30
			VAR OriginY = 8
			VAR SKUs = VALUES(Dim_Product[sku])
			VAR MinStock = MINX(SKUs, CALCULATE(AVERAGE(Fact[stock_available])))
			VAR MaxStock = MAXX(SKUs, CALCULATE(AVERAGE(Fact[stock_available])))
			VAR MinDemand = MINX(SKUs, CALCULATE([Avg Units Sold]))
			VAR MaxDemand = MAXX(SKUs, CALCULATE([Avg Units Sold]))
			VAR StockRange = MaxStock - MinStock
			VAR DemandRange = MaxDemand - MinDemand
			VAR StockThreshold = PERCENTILEX.INC(SKUs, CALCULATE(AVERAGE(Fact[stock_available])), 0.25)
			VAR DemandThreshold = PERCENTILEX.INC(SKUs, CALCULATE([Avg Units Sold]), 0.60)
			VAR Points =
			    CONCATENATEX(
			        SKUs,
			        VAR Stock = CALCULATE(AVERAGE(Fact[stock_available]))
			        VAR Demand = CALCULATE([Avg Units Sold])
			        VAR CX = OriginX + DIVIDE(Stock - MinStock, StockRange) * PlotW
			        VAR CY = OriginY + PlotH - DIVIDE(Demand - MinDemand, DemandRange) * PlotH
			        VAR IsRisk = Stock <= StockThreshold && Demand >= DemandThreshold
			        RETURN
			        "<circle cx='" & FORMAT(CX, "0.0") & "' cy='" & FORMAT(CY, "0.0") & "' r='" & IF(IsRisk, 5.5, 4.5) & "' fill='" & IF(IsRisk, "#c0392b", "#cfe4d6") & "'/>",
			        ""
			    )
			VAR RiskCount =
			    COUNTX(
			        FILTER(SKUs, CALCULATE(AVERAGE(Fact[stock_available])) <= StockThreshold && CALCULATE([Avg Units Sold]) >= DemandThreshold),
			        Dim_Product[sku]
			    )
			VAR InsightText =
			    RiskCount & " SKUs sit in the stockout alert zone — high rolling demand against thin available stock."
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:14px;font-family:sans-serif'>" &
			"<div style='font-size:12px;font-weight:600;color:#1a1a1a;margin-bottom:2px'>Stock risk matrix</div>" &
			"<div style='font-size:10px;color:#9a9a92;margin-bottom:10px'>Demand vs stock available</div>" &
			"<svg viewBox='0 0 300 100' xmlns='http://www.w3.org/2000/svg'>" &
			"<line x1='" & OriginX & "' y1='" & OriginY & "' x2='" & OriginX & "' y2='90' stroke='#e2e0d8' stroke-width='1'/>" &
			"<line x1='" & OriginX & "' y1='90' x2='290' y2='90' stroke='#e2e0d8' stroke-width='1'/>" &
			Points &
			"</svg>" &
			"<div style='background:#fbe4e4;border-radius:4px;padding:8px 10px;margin-top:8px;font-size:10.5px;color:#8a2f2f;line-height:1.5'>&#10022; " &
			InsightText &
			"</div>" &
			"</div>"
		lineageTag: 9e0f9f5c-54e8-4a7d-8a50-7197027d25dd

	measure 'PostPromoDip %' =
			
			VAR LastPromoDate = CALCULATE(MAX(Fact[date]), Fact[promotion_flag] = 1)
			VAR PostAvg =
			    CALCULATE([Avg Units Sold], Fact[date] > LastPromoDate && Fact[date] <= LastPromoDate + 28)
			RETURN DIVIDE(PostAvg - [Baseline Sales], [Baseline Sales])
		lineageTag: 0ef6da53-2348-454f-8501-1af18de42c1d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Stock Risk Callout Card' =
			
			VAR Combos = SUMMARIZE('Fact', Fact[region], Fact[channel])
			VAR RankedCombos =
			    ADDCOLUMNS(
			        Combos,
			        "@Rate", CALCULATE(DIVIDE(CALCULATE(COUNTROWS(Fact), Fact[stock_available] <= 5), COUNTROWS(Fact)))
			    )
			VAR TopCombo = TOPN(1, RankedCombos, [@Rate], DESC)
			VAR TopRegion = MAXX(TopCombo, Fact[region])
			VAR TopChannel = MAXX(TopCombo, Fact[channel])
			VAR TopRate = MAXX(TopCombo, [@Rate])
			VAR InsightText =
			    TopRegion & " region " & TopChannel & " channel shows a " & FORMAT(TopRate, "0%") &
			    " stockout rate. Raise safety stock for the top 5 SKUs before the next peak period."
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:12px 14px;border-left:3px solid #c0392b;font-family:sans-serif'>" &
			"<div style='font-size:11px;font-weight:600;color:#8a2f2f;margin-bottom:4px'>Stock risk</div>" &
			"<div style='font-size:10.5px;color:#4a4a44;line-height:1.55'>" & InsightText & "</div></div>"
		lineageTag: 80dd9fe3-c0ac-4874-b6ca-83cc17b5b5d4

	measure 'Budget Shift Callout Card' =
			
			VAR ChannelROI = ADDCOLUMNS(VALUES(Fact[channel]), "@ROI", CALCULATE([Overall Promo ROI]))
			VAR BestChannel = TOPN(1, ChannelROI, [@ROI], DESC)
			VAR WorstChannel = TOPN(1, ChannelROI, [@ROI], ASC)
			VAR BestName = MAXX(BestChannel, Fact[channel])
			VAR BestROI = MAXX(BestChannel, [@ROI])
			VAR WorstName = MAXX(WorstChannel, Fact[channel])
			VAR WorstROI = MAXX(WorstChannel, [@ROI])
			VAR Multiple = DIVIDE(BestROI, WorstROI)
			VAR InsightText =
			    "Promo ROI in " & BestName & " is " & FORMAT(Multiple, "0.0") & "x higher than " & WorstName &
			    " channel. Shift 20% of trade budget from " & WorstName & " to " & BestName & " in H1."
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:12px 14px;border-left:3px solid #1f6b45;font-family:sans-serif'>" &
			"<div style='font-size:11px;font-weight:600;color:#1f6b45;margin-bottom:4px'>Budget shift</div>" &
			"<div style='font-size:10.5px;color:#4a4a44;line-height:1.55'>" & InsightText & "</div></div>"
		lineageTag: a5dfcbb1-8686-45ce-84f2-6b97ed034719

	measure 'Seasonality Callout Card' =
			
			VAR TopSKU = MAXX(TOPN(1, VALUES(Dim_Product[sku]), CALCULATE([Avg Units Sold]), DESC), Dim_Product[sku])
			VAR MonthlyAvg =
			    ADDCOLUMNS(
			        VALUES(Dim_Date[month_name]),
			        "@U", CALCULATE([Avg Units Sold], Dim_Product[sku] = TopSKU)
			    )
			VAR PeakMonth = MAXX(TOPN(1, MonthlyAvg, [@U], DESC), Dim_Date[month_name])
			VAR PeakVal = MAXX(TOPN(1, MonthlyAvg, [@U], DESC), [@U])
			VAR TroughMonth = MAXX(TOPN(1, MonthlyAvg, [@U], ASC), Dim_Date[month_name])
			VAR TroughVal = MAXX(TOPN(1, MonthlyAvg, [@U], ASC), [@U])
			VAR DropPct = DIVIDE(PeakVal - TroughVal, PeakVal)
			VAR InsightText =
			    TopSKU & " demand peaks in " & PeakMonth & " and drops " & FORMAT(DropPct, "0%") &
			    " by " & TroughMonth & ". Align production and distribution to this seasonal pattern."
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:12px 14px;border-left:3px solid #c9932e;font-family:sans-serif'>" &
			"<div style='font-size:11px;font-weight:600;color:#a3641f;margin-bottom:4px'>Seasonality</div>" &
			"<div style='font-size:10.5px;color:#4a4a44;line-height:1.55'>" & InsightText & "</div></div>"
		lineageTag: d0a9b41b-b1e8-4743-9908-129897bb1a77

	measure 'Units This Month' = SUM(Fact[units_sold])
		formatString: 0
