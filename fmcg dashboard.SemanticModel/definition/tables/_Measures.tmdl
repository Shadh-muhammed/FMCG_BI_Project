	measure 'HTML - Stock Availability vs Sales Velocity' = ```
			
			
			-- Summarise one row per SKU: avg stock available + total units sold for 2024
			VAR _Data =
			    ADDCOLUMNS(
			        SUMMARIZE('Fact', Fact[sku]),
			        "@Stock", CALCULATE(AVERAGE(Fact[stock_available]), Dim_Date[year] = 2024),
			        "@Sales", CALCULATE(SUM(Fact[units_sold]),          Dim_Date[year] = 2024)
			    )
			
			-- Remove any SKUs with no 2024 data
			VAR _Clean =
			    FILTER(_Data, NOT ISBLANK([@Stock]) && NOT ISBLANK([@Sales]) && [@Sales] > 0)
			
			-- Axis bounds
			VAR _MinStock = MINX(_Clean, [@Stock])
			VAR _MaxStock = MAXX(_Clean, [@Stock])
			
			VAR _MinSales = MINX(_Clean, [@Sales])
			VAR _MaxSales = MAXX(_Clean, [@Sales])
			
			-- Quadrant midpoints (average of each axis)
			VAR _AvgStock = AVERAGEX(_Clean, [@Stock])
			VAR _AvgSales = AVERAGEX(_Clean, [@Sales])
			
			-- SVG canvas
			VAR _W    = 380
			VAR _H    = 170
			VAR _PadL = 42
			VAR _PadR = 10
			VAR _PadT = 24
			VAR _PadB = 28
			VAR _PlotW = _W - _PadL - _PadR
			VAR _PlotH = _H - _PadT - _PadB
			
			-- Quadrant divider pixel positions
			VAR _QX =
			    _PadL +
			    INT(
			        DIVIDE(
			            _AvgSales - _MinSales,
			            _MaxSales - _MinSales
			        ) * _PlotW
			    )
			
			VAR _QY =
			    _PadT +
			    INT(
			        _PlotH -
			        DIVIDE(
			            _AvgStock - _MinStock,
			            _MaxStock - _MinStock
			        ) * _PlotH
			    )
			
			-- Y-axis tick labels
			VAR _YMax = IF(_MaxStock >= 1000, FORMAT(_MaxStock/1000,"0.0") & "K", FORMAT(_MaxStock,"0"))
			VAR _YMid = IF(_AvgStock >= 1000, FORMAT(_AvgStock/1000,"0.0") & "K", FORMAT(_AvgStock,"0"))
			
			-- X-axis tick labels
			VAR _XMax = IF(_MaxSales >= 1000, FORMAT(_MaxSales/1000,"0.0") & "K", FORMAT(_MaxSales,"0"))
			VAR _XMid = IF(_AvgSales >= 1000, FORMAT(_AvgSales/1000,"0.0") & "K", FORMAT(_AvgSales,"0"))
			
			-- Generate one SVG circle per SKU
			VAR _Dots =
			    CONCATENATEX(
			        _Clean,
			        VAR _cx =
			    _PadL +
			    INT(
			        DIVIDE(
			            [@Sales] - _MinSales,
			            _MaxSales - _MinSales
			        ) * _PlotW
			    )
			
			    VAR _cy =
			    _PadT +
			    INT(
			        _PlotH -
			        DIVIDE(
			            [@Stock] - _MinStock,
			            _MaxStock - _MinStock
			        ) * _PlotH
			    )
			        VAR _clr =
			            SWITCH(
			                TRUE(),
			                [@Stock] >= _AvgStock && [@Sales] >= _AvgSales, "#1B9E75",  -- Healthy
			                [@Stock] <  _AvgStock && [@Sales] >= _AvgSales, "#E74C3C",  -- Stockout risk
			                [@Stock] >= _AvgStock && [@Sales] <  _AvgSales, "#8E44AD",  -- Dead inventory
			                "#F0A500"                                                     -- Review
			            )
			        RETURN
			        "<circle cx='" & _cx & "' cy='" & _cy &
			        "' r='5' fill='" & _clr & "' fill-opacity='0.75' stroke='#fff' stroke-width='0.8'>" &
			        "<title>" & Fact[sku] & "</title></circle>",
			        "",
			        [@Sales], ASC
			    )
			
			RETURN
			
			"<div style='font-family:Segoe UI,Arial,sans-serif;padding:16px 18px;
			background:#FFFFFF;border-radius:10px;height:90%;box-sizing:border-box;'>
			
			<div style='display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;'>
			<span style='font-size:10px;font-weight:700;letter-spacing:1px;color:#222;text-transform:uppercase;'>
			Stock Availability vs Sales Velocity · By SKU
			</span>
			<span style='font-size:10px;color:#aaa;'>Stockout risk matrix</span>
			</div>
			
			<svg width='100%' viewBox='0 0 " & _W & " " & _H & "' xmlns='http://www.w3.org/2000/svg'>
			
			  <!-- Plot area background -->
			  <rect x='" & _PadL & "' y='" & _PadT & "'
			        width='" & _PlotW & "' height='" & _PlotH & "'
			        fill='#FAFAFA' stroke='#EBEBEB' stroke-width='1'/>
			
			  <!-- Quadrant dividers (dashed) -->
			  <line x1='" & _QX & "' y1='" & _PadT & "'
			        x2='" & _QX & "' y2='" & (_PadT + _PlotH) & "'
			        stroke='#CCCCCC' stroke-width='1' stroke-dasharray='4 3'/>
			  <line x1='" & _PadL & "' y1='" & _QY & "'
			        x2='" & (_PadL + _PlotW) & "' y2='" & _QY & "'
			        stroke='#CCCCCC' stroke-width='1' stroke-dasharray='4 3'/>
			
			  <!-- Quadrant corner labels -->
			  <text x='" & (_PadL + 4) & "' y='" & (_PadT + 10) & "'
			        font-size='7' fill='#CCCCCC' font-style='italic'>High Stock · Low Sales</text>
			
			  <text x='" & (_PadL + _PlotW - 4) & "' y='" & (_PadT + 10) & "'
			        font-size='7' fill='#BBBBBB' font-style='italic' text-anchor='end'>Sweet spot</text>
			
			  <text x='" & (_PadL + 4) & "' y='" & (_PadT + _PlotH - 5) & "'
			        font-size='7' fill='#E74C3C' fill-opacity='0.55' font-style='italic'>Stockout risk</text>
			
			  <text x='" & (_PadL + _PlotW - 4) & "' y='" & (_PadT + _PlotH - 5) & "'
			        font-size='7' fill='#8E44AD' fill-opacity='0.55' font-style='italic' text-anchor='end'>Dead inventory</text>
			
			  <!-- Y axis line + labels -->
			  <line x1='" & _PadL & "' y1='" & _PadT & "'
			        x2='" & _PadL & "' y2='" & (_PadT + _PlotH) & "'
			        stroke='#CCCCCC' stroke-width='1'/>
			
			  <text x='" & (_PadL - 4) & "' y='" & (_PadT + 4) & "'
			        text-anchor='end' font-size='7' fill='#AAAAAA'>" & _YMax & "</text>
			
			  <text x='" & (_PadL - 4) & "' y='" & _QY & "'
			        text-anchor='end' font-size='7' fill='#AAAAAA' dy='3'>" & _YMid & "</text>
			
			  <text x='" & (_PadL - 4) & "' y='" & (_PadT + _PlotH) & "'
			        text-anchor='end' font-size='7' fill='#AAAAAA'>0</text>
			
			  <!-- Y axis title (rotated) -->
			  <text x='10' y='" & (_PadT + _PlotH / 2) & "'
			        text-anchor='middle' font-size='7.5' fill='#999999'
			        transform='rotate(-90 10 " & (_PadT + _PlotH / 2) & ")'>Stock Available</text>
			
			  <!-- X axis line + labels -->
			  <line x1='" & _PadL & "' y1='" & (_PadT + _PlotH) & "'
			        x2='" & (_PadL + _PlotW) & "' y2='" & (_PadT + _PlotH) & "'
			        stroke='#CCCCCC' stroke-width='1'/>
			
			  <text x='" & _PadL & "' y='" & (_PadT + _PlotH + 14) & "'
			        text-anchor='middle' font-size='7' fill='#AAAAAA'>0</text>
			
			  <text x='" & _QX & "' y='" & (_PadT + _PlotH + 14) & "'
			        text-anchor='middle' font-size='7' fill='#AAAAAA'>" & _XMid & "</text>
			
			  <text x='" & (_PadL + _PlotW) & "' y='" & (_PadT + _PlotH + 14) & "'
			        text-anchor='end' font-size='7' fill='#AAAAAA'>" & _XMax & "</text>
			
			  <text x='" & (_PadL + _PlotW / 2) & "' y='" & (_PadT + _PlotH + 24) & "'
			        text-anchor='middle' font-size='7.5' fill='#999999'>Units Sold →</text>
			
			  <!-- SKU dots -->
			  " & _Dots & "
			
			</svg>
			
			<!-- Legend -->
			<div style='display:flex;gap:14px;font-size:10px;color:#555;margin-top:2px;flex-wrap:wrap;'>
			<span><span style='color:#1B9E75;font-size:14px;'>●</span> Healthy</span>
			<span><span style='color:#E74C3C;font-size:14px;'>●</span> Stockout risk</span>
			<span><span style='color:#8E44AD;font-size:14px;'>●</span> Dead stock</span>
			<span><span style='color:#F0A500;font-size:14px;'>●</span> Review</span>
			</div>
			
			</div>"
			
			```
		lineageTag: d761a40e-63d7-4e9e-82c0-9f70f1f96b68

	measure HTML_EcomRevTrend =
			
			
			-- ── CHART DIMENSIONS ────────────────────────────────────────────────
			VAR _W  = 640
			VAR _H  = 220
			VAR _PL = 12         -- padding left
			VAR _PR = 12         -- padding right
			VAR _PT = 14         -- padding top
			VAR _PB = 30         -- padding bottom (space for x-axis labels)
			VAR _CW = _W - _PL - _PR     -- chart draw width
			VAR _CH = _H - _PT - _PB     -- chart draw height
			
			-- ── RAW DATA: E-Commerce revenue, monthly, all 3 years ──────────────
			-- SUMMARIZE groups the E-Com filtered Fact by year + month from Dim_Date
			-- ADDCOLUMNS then computes the actual SUM per group via context transition
			VAR _Raw =
			    ADDCOLUMNS(
			        SUMMARIZE(
			            CALCULATETABLE( 'Fact', Dim_channel[channel] = "E-Commerce" ),
			            Dim_Date[year],
			            Dim_Date[month]
			        ),
			        "Rev",
			        CALCULATE(
			            SUM( Fact[Sales Amount] ),
			            Dim_channel[channel] = "E-Commerce"
			        )
			    )
			
			-- Scale anchor: highest monthly value across all 3 years
			VAR _MaxRev = MAXX( _Raw, [Rev] )
			VAR _Sc     = IF( _MaxRev = 0, 1, _MaxRev )
			
			-- Split by year for separate polylines
			VAR _D22 = FILTER( _Raw, [year] = 2022 )
			VAR _D23 = FILTER( _Raw, [year] = 2023 )
			VAR _D24 = FILTER( _Raw, [year] = 2024 )
			
			-- ── POLYLINE COORDINATE BUILDER ──────────────────────────────────────
			-- X: maps month 1→12 across chart width
			-- Y: maps Rev to chart height (SVG y=0 is top, so we invert)
			
			VAR _P22 =
			    CONCATENATEX(
			        ADDCOLUMNS( _D22,
			            "PX", FORMAT( _PL + ( ( [month] - 1 ) / 11 ) * _CW, "0.0" ),
			            "PY", FORMAT( _PT + _CH - ( [Rev] / _Sc ) * _CH,    "0.0" )
			        ),
			        [PX] & "," & [PY],
			        " ",
			        [month], ASC
			    )
			
			VAR _P23 =
			    CONCATENATEX(
			        ADDCOLUMNS( _D23,
			            "PX", FORMAT( _PL + ( ( [month] - 1 ) / 11 ) * _CW, "0.0" ),
			            "PY", FORMAT( _PT + _CH - ( [Rev] / _Sc ) * _CH,    "0.0" )
			        ),
			        [PX] & "," & [PY],
			        " ",
			        [month], ASC
			    )
			
			VAR _P24 =
			    CONCATENATEX(
			        ADDCOLUMNS( _D24,
			            "PX", FORMAT( _PL + ( ( [month] - 1 ) / 11 ) * _CW, "0.0" ),
			            "PY", FORMAT( _PT + _CH - ( [Rev] / _Sc ) * _CH,    "0.0" )
			        ),
			        [PX] & "," & [PY],
			        " ",
			        [month], ASC
			    )
			
			-- ── X-AXIS MONTH LABELS (Jan, Mar, May, Jul, Sep, Nov, Dec) ─────────
			VAR _XLabels =
			    CONCATENATEX(
			        FILTER(
			            ADDCOLUMNS(
			                GENERATESERIES( 1, 12, 1 ),
			                "Lbl",  SWITCH( [Value],
			                            1,"Jan",  2,"Feb",  3,"Mar",  4,"Apr",
			                            5,"May",  6,"Jun",  7,"Jul",  8,"Aug",
			                            9,"Sep",  10,"Oct", 11,"Nov", 12,"Dec" ),
			                "Show", SWITCH( [Value], 1,1, 3,1, 5,1, 7,1, 9,1, 11,1, 12,1, 0 ),
			                "XP",   _PL + ( ( [Value] - 1 ) / 11 ) * _CW
			            ),
			            [Show] = 1
			        ),
			        "<text x='" & FORMAT( [XP], "0.0" ) & "'
			               y='" & FORMAT( _PT + _CH + 18, "0" ) & "'
			               text-anchor='middle'
			               font-size='9.5' fill='#aaa'>" & [Lbl] & "</text>",
			        "",
			        [Value], ASC
			    )
			
			-- ── HORIZONTAL GRID LINES (4 lines across chart) ────────────────────
			VAR _Grids =
			    CONCATENATEX(
			        ADDCOLUMNS(
			            GENERATESERIES( 1, 4, 1 ),
			            "GY", FORMAT( _PT + ( [Value] / 4 ) * _CH, "0.0" )
			        ),
			        "<line x1='" & FORMAT( _PL, "0" ) & "' y1='" & [GY] & "'
			               x2='" & FORMAT( _PL + _CW, "0" ) & "' y2='" & [GY] & "'
			               stroke='#efefef' stroke-width='1'/>",
			        "",
			        [Value], ASC
			    )
			
			-- ── FOOTER: Dynamic E-Com growth 2022→2024 for Central ──────────────
			VAR _EC22C =
			    CALCULATE( SUM( Fact[Sales Amount] ),
			        Dim_channel[channel] = "E-Commerce",
			        Dim_Date[year]       = 2022,
			        Dim_region[region]   = "Central" )
			VAR _EC24C =
			    CALCULATE( SUM( Fact[Sales Amount] ),
			        Dim_channel[channel] = "E-Commerce",
			        Dim_Date[year]       = 2024,
			        Dim_region[region]   = "Central" )
			VAR _Grw   = IF( _EC22C <> 0, ( _EC24C - _EC22C ) / _EC22C * 100, BLANK() )
			VAR _GrwSt = FORMAT( _Grw, "+0.0;-0.0" ) & "%"
			
			-- ── ASSEMBLE HTML ────────────────────────────────────────────────────
			RETURN
			"<div style='font-family:Segoe UI,sans-serif;padding:12px 14px;
			             background:#fff;border-radius:6px;box-sizing:border-box;'>
			
			  <!-- HEADER ROW -->
			  <div style='display:flex;justify-content:space-between;
			              align-items:baseline;margin-bottom:6px;'>
			    <span style='font-size:11px;font-weight:700;
			                 letter-spacing:.07em;color:#1a1a1a;'>
			      E-COMMERCE CHANNEL · REVENUE TREND
			    </span>
			    <span style='font-size:10px;color:#aaa;'>Month over month — AED</span>
			  </div>
			
			  <!-- LEGEND -->
			  <div style='display:flex;gap:18px;margin-bottom:4px;'>
			    <span style='font-size:10px;color:#14532d;font-weight:700;'>—— 2024</span>
			    <span style='font-size:10px;color:#0e7490;'>—— 2023</span>
			    <span style='font-size:10px;color:#bbb;'>- - 2022</span>
			  </div>
			
			  <!-- SVG CHART -->
			  <svg width='100%' viewBox='0 0 " & FORMAT(_W,"0") & " " & FORMAT(_H,"0") & "'
			       xmlns='http://www.w3.org/2000/svg'>
			
			    " & _Grids & "
			
			    <!-- 2022: light dashed -->
			    <polyline points='" & _P22 & "'
			      fill='none' stroke='#d1d5db' stroke-width='1.5' stroke-dasharray='5,3'/>
			
			    <!-- 2023: teal solid -->
			    <polyline points='" & _P23 & "'
			      fill='none' stroke='#0e7490' stroke-width='2'/>
			
			    <!-- 2024: dark green bold -->
			    <polyline points='" & _P24 & "'
			      fill='none' stroke='#14532d' stroke-width='3'/>
			
			    " & _XLabels & "
			
			  </svg>
			
			  <!-- INSIGHT CALLOUT -->
			  <div style='margin-top:4px;padding:5px 10px;
			              background:#fffbeb;border-left:3px solid #d97706;
			              font-size:10px;color:#555;border-radius:0 3px 3px 0;'>
			    ✦ E-Commerce grew " & _GrwSt & " in Central 2022–2024
			      — separate channel investment case
			  </div>
			
			</div>"
		lineageTag: bc26a9cb-58bd-4263-89f9-805bc6a607cc

	measure HTML_AvgDeliveryRegion =
			
			
			-- ── CONFIG ──────────────────────────────────────────────────────────
			VAR _Target   = 2     -- target delivery days (hardcoded; adjust if from Dim_Target)
			VAR _MaxScale = 6.0      -- axis ceiling (keeps bar proportions stable across refreshes)
			VAR _BarMaxW  = 420      -- max bar pixel width in SVG
			VAR _BarH     = 22       -- bar height in px
			VAR _LabelW   = 62       -- region label column width
			VAR _RowGap   = 20       -- vertical gap between bar rows
			VAR _SVGW     = _LabelW + _BarMaxW + 24
			
			-- ── DATA: average delivery days per region ───────────────────────────
			VAR _RegData =
			    ADDCOLUMNS(
			        VALUES( Dim_region[region] ),
			        "AvgDel", CALCULATE( AVERAGE( Fact[delivery_days] ) )
			    )
			
			-- ── ENRICH: bar width, rank (for row order), color, label ───────────
			-- Color logic:
			--   Green  = on/under target
			--   Orange = up to 10% over target
			--   Red    = more than 10% over target
			VAR _Enriched =
			    ADDCOLUMNS(
			        _RegData,
			        "BarW",  MIN( [AvgDel] / _MaxScale * _BarMaxW,  _BarMaxW ),
			        "Rank",  RANKX( _RegData, [AvgDel],, DESC ),     -- highest del days = row 1
			        "Color", IF( [AvgDel] <= _Target,                "#166534",
			                 IF( [AvgDel] <= _Target * 1.10,         "#c2410c",
			                                                          "#b91c1c" ) ),
			        "Lbl",   FORMAT( [AvgDel], "0.0" ) & "d"
			    )
			
			-- ── FINAL PASS: add pixel Y positions (depends on Rank) ──────────────
			VAR _WithPos =
			    ADDCOLUMNS(
			        _Enriched,
			        "RowY",  ( [Rank] - 1 ) * _RowGap + 4,
			        "TextY", ( [Rank] - 1 ) * _RowGap + 4 + _BarH - 6
			    )
			
			-- ── SVG HEIGHT ────────────────────────────────────────────────────────
			VAR _NumReg = COUNTROWS( _RegData )
			VAR _SVGH = _NumReg * _RowGap + 10
			
			-- ── TARGET LINE X position ───────────────────────────────────────────
			VAR _TargetX = FORMAT( _LabelW + ( _Target / _MaxScale ) * _BarMaxW, "0.0" )
			
			-- ── BAR ROWS ─────────────────────────────────────────────────────────
			VAR _Bars =
			    CONCATENATEX(
			        _WithPos,
			        -- Region label
			        "<text x='0' y='" & FORMAT( [TextY], "0" ) & "'
			               font-size='11' font-weight='600' fill='#444'>" & [region] & "</text>"
			
			        -- Background track
			        & "<rect x='" & FORMAT( _LabelW, "0" ) & "'
			                y='" & FORMAT( [RowY], "0" ) & "'
			                width='" & FORMAT( _BarMaxW, "0" ) & "'
			                height='" & FORMAT( _BarH, "0" ) & "'
			                fill='#f3f4f6' rx='3'/>"
			
			        -- Coloured bar
			        & "<rect x='" & FORMAT( _LabelW, "0" ) & "'
			                y='" & FORMAT( [RowY], "0" ) & "'
			                width='" & FORMAT( [BarW], "0.0" ) & "'
			                height='" & FORMAT( _BarH, "0" ) & "'
			                fill='" & [Color] & "' rx='3'/>"
			
			        -- Value label inside bar
			        & "<text x='" & FORMAT( _LabelW + 8, "0" ) & "'
			                y='" & FORMAT( [TextY], "0" ) & "'
			                font-size='11' font-weight='700' fill='#fff'>" & [Lbl] & "</text>",
			
			        "",
			        [AvgDel], DESC       -- Central (highest) first
			    )
			
			-- ── FOOTER: dynamic on-track region name ─────────────────────────────
			VAR _OnTrackNames =
			    CONCATENATEX( FILTER( _RegData, [AvgDel] <= _Target ), [region], ", " )
			VAR _OnTrackCount =
			    COUNTROWS( FILTER( _RegData, [AvgDel] <= _Target ) )
			VAR _FooterTxt =
			    "| Target = " & FORMAT( _Target, "0.0" ) & "d  ("
			    & _OnTrackNames
			    & " only region" & IF( _OnTrackCount = 1, "", "s" ) & " on track)"
			
			-- ── ASSEMBLE HTML ────────────────────────────────────────────────────
			RETURN
			"<div style='font-family:Segoe UI,sans-serif;padding:12px 14px;
			             background:#fff;border-radius:6px;box-sizing:border-box;'>
			
			  <!-- HEADER ROW -->
			  <div style='display:flex;justify-content:space-between;
			              align-items:baseline;margin-bottom:12px;'>
			    <span style='font-size:11px;font-weight:700;
			                 letter-spacing:.07em;color:#1a1a1a;'>
			      AVG DELIVERY DAYS · BY REGION
			    </span>
			    <span style='font-size:10px;color:#aaa;'>
			      Target: " & FORMAT( _Target, "0.0" ) & " days
			    </span>
			  </div>
			
			  <!-- SVG BAR CHART -->
			  <svg width='100%'
			       viewBox='0 0 " & FORMAT( _SVGW, "0" ) & " " & FORMAT( _SVGH, "0" ) & "'
			       xmlns='http://www.w3.org/2000/svg'>
			
			    " & _Bars & "
			
			    <!-- Dashed target line -->
			    <line x1='" & _TargetX & "' y1='0'
			          x2='" & _TargetX & "' y2='" & FORMAT( _SVGH, "0" ) & "'
			          stroke='#9ca3af' stroke-width='1.5' stroke-dasharray='4,3'/>
			
			  </svg>
			
			  <!-- INSIGHT FOOTER -->
			  <div style='margin-top:6px;padding:5px 10px;
			              background:#f9fafb;border-left:3px solid #9ca3af;
			              font-size:10px;color:#6b7280;border-radius:0 3px 3px 0;'>
			    " & _FooterTxt & "
			  </div>
			
			</div>"
		lineageTag: 294a501d-f05d-44a8-bae1-6eb4f042a818

	measure HTML_SKUChannelPerf =
			
			
			VAR _ChanR = "Retail"
			VAR _ChanE = "E-Commerce"
			VAR _ChanD = "Discount"
			VAR _TopN  = 8
			
			-- TOP N SKUs by total revenue
			VAR _AllSKU =
			    ADDCOLUMNS(
			        VALUES( Dim_Product[Product_id] ),
			        "TotalRev", CALCULATE( SUM( Fact[Sales Amount] ) )
			    )
			
			VAR _TopSKUs =
			    TOPN( _TopN, _AllSKU, [TotalRev], DESC )
			
			-- Channel revenue per SKU
			VAR _Pivot =
			    ADDCOLUMNS(
			        _TopSKUs,
			        "RevR", CALCULATE( SUM( Fact[Sales Amount] ), Dim_channel[channel] = _ChanR ),
			        "RevE", CALCULATE( SUM( Fact[Sales Amount] ), Dim_channel[channel] = _ChanE ),
			        "RevD", CALCULATE( SUM( Fact[Sales Amount] ), Dim_channel[channel] = _ChanD )
			    )
			
			-- Max per channel (guard against all-blank)
			VAR _MaxR = IFERROR( MAXX( _Pivot, [RevR] ), 1 )
			VAR _MaxE = IFERROR( MAXX( _Pivot, [RevE] ), 1 )
			VAR _MaxD = IFERROR( MAXX( _Pivot, [RevD] ), 1 )
			
			-- Normalise to nearest 20% bucket
			VAR _PivotN =
			    ADDCOLUMNS(
			        _Pivot,
			        "NR", IF( [RevR] > 0 && _MaxR > 0, MROUND( [RevR] / _MaxR * 100, 20 ), 0 ),
			        "NE", IF( [RevE] > 0 && _MaxE > 0, MROUND( [RevE] / _MaxE * 100, 20 ), 0 ),
			        "ND", IF( [RevD] > 0 && _MaxD > 0, MROUND( [RevD] / _MaxD * 100, 20 ), 0 )
			    )
			
			-- Build table rows
			VAR _Rows =
			    CONCATENATEX(
			        _PivotN,
			
			        VAR _NR = [NR]
			        VAR _NE = [NE]
			        VAR _ND = [ND]
			
			        -- Badge background colours (teal scale matching dashboard theme)
			        VAR _BR =
			            SWITCH( TRUE(),
			                _NR >= 100, "#0B5E4B",
			                _NR >= 80,  "#1D9E75",
			                _NR >= 60,  "#5DCAA5",
			                _NR >= 40,  "#C9940A",
			                _NR >= 20,  "#E8E6DF",
			                            "#F4F3F0"
			            )
			        VAR _BE =
			            SWITCH( TRUE(),
			                _NE >= 100, "#0B5E4B",
			                _NE >= 80,  "#1D9E75",
			                _NE >= 60,  "#5DCAA5",
			                _NE >= 40,  "#C9940A",
			                _NE >= 20,  "#E8E6DF",
			                            "#F4F3F0"
			            )
			        VAR _BD =
			            SWITCH( TRUE(),
			                _ND >= 100, "#0B5E4B",
			                _ND >= 80,  "#1D9E75",
			                _ND >= 60,  "#5DCAA5",
			                _ND >= 40,  "#C9940A",
			                _ND >= 20,  "#E8E6DF",
			                            "#F4F3F0"
			            )
			
			        -- Badge text colours
			        VAR _TR = IF( _NR >= 60, "#ffffff", IF( _NR >= 40, "#1a1a1a", "#9ca3af" ) )
			        VAR _TE = IF( _NE >= 60, "#ffffff", IF( _NE >= 40, "#1a1a1a", "#9ca3af" ) )
			        VAR _TD = IF( _ND >= 60, "#ffffff", IF( _ND >= 40, "#1a1a1a", "#9ca3af" ) )
			
			        -- Badge labels
			        VAR _LR = IF( _NR = 0, UNICHAR(8212), FORMAT( _NR, "0" ) & "%" )
			        VAR _LE = IF( _NE = 0, UNICHAR(8212), FORMAT( _NE, "0" ) & "%" )
			        VAR _LD = IF( _ND = 0, UNICHAR(8212), FORMAT( _ND, "0" ) & "%" )
			
			        -- Reusable badge snippet (inline-block is the key fix — prevents full-width stretch)
			        VAR _Badge_R =
			            "<div style='display:inline-block;background:" & _BR & ";color:" & _TR
			            & ";border-radius:4px;padding:3px 10px;font-size:11px;font-weight:700;"
			            & "min-width:46px;text-align:center;'>" & _LR & "</div>"
			
			        VAR _Badge_E =
			            "<div style='display:inline-block;background:" & _BE & ";color:" & _TE
			            & ";border-radius:4px;padding:3px 10px;font-size:11px;font-weight:700;"
			            & "min-width:46px;text-align:center;'>" & _LE & "</div>"
			
			        VAR _Badge_D =
			            "<div style='display:inline-block;background:" & _BD & ";color:" & _TD
			            & ";border-radius:4px;padding:3px 10px;font-size:11px;font-weight:700;"
			            & "min-width:46px;text-align:center;'>" & _LD & "</div>"
			
			        RETURN
			            "<tr>"
			            & "<td class='sku-cell'>" & [Product_id] & "</td>"
			            & "<td class='val-cell'>" & _Badge_R & "</td>"
			            & "<td class='val-cell'>" & _Badge_E & "</td>"
			            & "<td class='val-cell'>" & _Badge_D & "</td>"
			            & "</tr>",
			
			        UNICHAR(10),
			        [TotalRev],
			        DESC
			    )
			
			-- Legend row (matches dashboard reference)
			VAR _Legend =
			    "<div class='legend'>"
			    & "<span class='dot' style='background:#0B5E4B'></span>Very High &nbsp;"
			    & "<span class='dot' style='background:#1D9E75'></span>High &nbsp;"
			    & "<span class='dot' style='background:#5DCAA5'></span>Med &nbsp;"
			    & "<span class='dot' style='background:#E8E6DF;border:1px solid #ccc'></span>Low &nbsp;"
			    & "<span class='dot' style='background:#F4F3F0;border:1px solid #ccc'></span>Minimal"
			    & "</div>"
			
			-- Full HTML document — this is what was missing before
			VAR _HTML =
			    "<!DOCTYPE html><html><head><meta charset='utf-8'><style>"
			
			    -- Reset & base
			    & "* { box-sizing:border-box; margin:0; padding:0; }"
			    & "body { font-family: 'Segoe UI', Arial, sans-serif; font-size:12px;"
			    &        "background:#fff; padding:10px; }"
			
			    -- Legend
			    & ".legend { display:flex; align-items:center; gap:4px; flex-wrap:wrap;"
			    &           "font-size:10px; color:#6b7280; margin-bottom:10px; }"
			    & ".dot { display:inline-block; width:10px; height:10px;"
			    &        "border-radius:2px; margin-right:3px; }"
			
			    -- Table structure
			    & "table { width:100%; border-collapse:collapse; }"
			
			    -- Header
			    & "thead th { padding:6px 8px; font-size:10px; font-weight:600;"
			    &            "color:#6b7280; text-transform:uppercase; letter-spacing:.04em;"
			    &            "border-bottom:2px solid #e5e7eb; background:#fafafa; }"
			    & "thead th:first-child { text-align:left; }"
			    & "thead th:not(:first-child) { text-align:center; }"
			
			    -- Body cells
			    & ".sku-cell { padding:6px 10px; font-size:11px; font-weight:600;"
			    &             "color:#374151; white-space:nowrap; }"
			    & ".val-cell { padding:5px 6px; text-align:center;"
			    &             "vertical-align:middle; }"
			
			    -- Row dividers and hover
			    & "tbody tr { border-bottom:1px solid #f0efec; }"
			    & "tbody tr:last-child { border-bottom:none; }"
			    & "tbody tr:hover { background:#f9fafb; }"
			
			    & "</style></head><body>"
			
			    -- Header
			    & "<div style='display:flex;justify-content:space-between;align-items:baseline;margin-bottom:18px;'>"
			    & "<span style='font-size:10px;font-weight:700;letter-spacing:1px;color:#222;text-transform:uppercase;'>SKU X Channel Performance</span>"
			    & "<span style='font-size:10px;color:#aaa;'>Revenue Contribution</span>"
			    & "</div>"
			
			    -- Legend below the header
			    & _Legend
			
			    -- Table
			    & "<table>"
			    & "<thead><tr>"
			    & "<th>SKU</th>"
			    & "<th>Retail</th>"
			    & "<th>E-Commerce</th>"
			    & "<th>Discount</th>"
			    & "</tr></thead>"
			    & "<tbody>" & _Rows & "</tbody>"
			    & "</table>"
			    & "</body></html>"
			
			RETURN _HTML
		lineageTag: d580f880-e87a-4ed7-b9f6-067a746d7d47

	measure HTML_RevenuePareto =
			
			
			-- ══ CONFIG ════════════════════════════════════════════════════════
			VAR _TopN      = 10       -- bars to show individually
			VAR _ParetoTgt = 0.80     -- 80% threshold
			VAR _SVGW      = 580
			VAR _SVGH      = 235
			VAR _ML        = 44       -- left margin (revenue axis)
			VAR _MR        = 38       -- right margin (cumulative % axis)
			VAR _MT        = 14
			VAR _MB        = 54       -- bottom margin for rotated labels
			VAR _CW        = _SVGW - _ML - _MR
			VAR _CH        = _SVGH - _MT - _MB
			
			-- ══ STEP A · ALL SKU REVENUE (filter out blanks) ═══════════════════
			VAR _AllSKU =
			    FILTER(
			        ADDCOLUMNS(
			            VALUES( Dim_Product[Product_id] ),
			            "Rev", CALCULATE( SUM( Fact[Sales Amount] ) )
			        ),
			        NOT ISBLANK( [Rev] ) && [Rev] > 0
			    )
			
			VAR _TotalRev   = SUMX( _AllSKU, [Rev] )
			VAR _TotalCount = COUNTROWS( _AllSKU )
			
			-- ══ STEP B · TOP N FOR CHART DISPLAY ══════════════════════════════
			VAR _TopSKUs = TOPN( _TopN, _AllSKU, [Rev], DESC )
			
			VAR _Ranked =
			    ADDCOLUMNS(
			        _TopSKUs,
			        "Rk", RANKX( _TopSKUs, [Rev],, DESC, Dense )
			    )
			
			-- Cumulative % for top N (for chart line)
			VAR _WithCumul =
			    ADDCOLUMNS(
			        _Ranked,
			        "CumPct",
			        VAR _R = [Rk]
			        RETURN
			            IF( _TotalRev > 0,
			                SUMX( FILTER( _Ranked, [Rk] <= _R ), [Rev] ) / _TotalRev,
			                0 )
			    )
			
			-- ══ STEP C · ALL-SKU CUMULATIVE for Pareto Count ══════════════════
			-- Separate from top-N so count is accurate even if 80% falls in Others
			VAR _AllRanked =
			    ADDCOLUMNS(
			        _AllSKU,
			        "Rk_All", RANKX( _AllSKU, [Rev],, DESC, Dense )
			    )
			
			VAR _AllCumul =
			    ADDCOLUMNS(
			        _AllRanked,
			        "CumRev",
			        VAR _R = [Rk_All]
			        RETURN SUMX( FILTER( _AllRanked, [Rk_All] <= _R ), [Rev] )
			    )
			
			VAR _ParetoSKUs =
			    MINX( FILTER( _AllCumul, [CumRev] >= _TotalRev * _ParetoTgt ), [Rk_All] )
			VAR _RemCount = _TotalCount - _ParetoSKUs
			
			-- ══ STEP D · OTHERS BUCKET ════════════════════════════════════════
			VAR _TopRev   = SUMX( _TopSKUs, [Rev] )
			VAR _OtherRev = _TotalRev - _TopRev
			
			-- ══ STEP E · BAR SCALE & GEOMETRY ════════════════════════════════
			VAR _MaxRev    = MAXX( _WithCumul, [Rev] )
			VAR _MaxRevScl = _MaxRev * 1.05     -- 5% headroom above tallest bar
			
			VAR _NItems  = _TopN + 1
			VAR _SlotW   = _CW / _NItems
			VAR _BarW    = _SlotW * 0.62
			VAR _BarGap  = ( _SlotW - _BarW ) / 2
			
			-- ══ STEP F · BARS (Top N) ════════════════════════════════════════
			VAR _Bars =
			    CONCATENATEX(
			        _WithCumul,
			        VAR _BX = _ML + ( [Rk] - 1 ) * _SlotW + _BarGap
			        VAR _BH = INT( ( [Rev] / _MaxRevScl ) * _CH )
			        VAR _BY = _MT + _CH - _BH
			        RETURN
			        "<rect x='"      & FORMAT( _BX,   "0.0" ) & "'
			               y='"      & FORMAT( _BY,   "0"   ) & "'
			               width='"  & FORMAT( _BarW, "0.0" ) & "'
			               height='" & FORMAT( _BH,   "0"   ) & "'
			               fill='#14532d' rx='2'/>",
			        "",
			        [Rk], ASC
			    )
			
			-- ══ STEP G · OTHERS BAR (lighter colour) ═════════════════════════
			VAR _OtherBX = _ML + _TopN * _SlotW + _BarGap
			VAR _OtherBH = INT( ( _OtherRev / _MaxRevScl ) * _CH )
			VAR _OtherBY = _MT + _CH - _OtherBH
			VAR _OtherBar =
			    "<rect x='"      & FORMAT( _OtherBX, "0.0" ) & "'
			           y='"      & FORMAT( _OtherBY, "0"   ) & "'
			           width='"  & FORMAT( _BarW,    "0.0" ) & "'
			           height='" & FORMAT( _OtherBH, "0"   ) & "'
			           fill='#a3c4a8' rx='2'/>"
			
			-- ══ STEP H · CUMULATIVE LINE + CIRCLES ════════════════════════════
			VAR _LinePoints =
			    CONCATENATEX(
			        _WithCumul,
			        FORMAT( _ML + ( [Rk] - 0.5 ) * _SlotW, "0.0" )
			        & "," &
			        FORMAT( _MT + _CH - ( [CumPct] * _CH ), "0.0" ),
			        " ",
			        [Rk], ASC
			    )
			
			-- Final point: Others at 100%
			VAR _OtherXC   = _ML + ( _TopN + 0.5 ) * _SlotW
			VAR _FullLine  = _LinePoints & " " & FORMAT( _OtherXC, "0.0" ) & "," & FORMAT( _MT, "0" )
			
			VAR _Circles =
			    CONCATENATEX(
			        _WithCumul,
			        VAR _CX = _ML + ( [Rk] - 0.5 ) * _SlotW
			        VAR _CY = _MT + _CH - ( [CumPct] * _CH )
			        RETURN
			        "<circle cx='" & FORMAT( _CX, "0.0" ) & "'
			                 cy='" & FORMAT( _CY, "0.0" ) & "'
			                 r='3' fill='#d97706' stroke='#fff' stroke-width='1.2'/>",
			        "",
			        [Rk], ASC
			    )
			
			VAR _OtherCircle =
			    "<circle cx='" & FORMAT( _OtherXC, "0.0" ) & "'
			             cy='" & FORMAT( _MT, "0" ) & "'
			             r='3' fill='#d97706' stroke='#fff' stroke-width='1.2'/>"
			
			-- ══ STEP I · X-AXIS LABELS (rotated -45°) ═════════════════════════
			VAR _XLabels =
			    CONCATENATEX(
			        _WithCumul,
			        VAR _XC  = _ML + ( [Rk] - 0.5 ) * _SlotW
			        VAR _YLb = _MT + _CH + 5
			        RETURN
			        "<text transform='rotate(-45 " & FORMAT( _XC, "0.0" ) & " " & FORMAT( _YLb, "0" ) & ")'
			               x='"         & FORMAT( _XC, "0.0" ) & "'
			               y='"         & FORMAT( _YLb, "0"  ) & "'
			               font-size='9' fill='#6b7280' text-anchor='end'>"
			        & [Product_id] & "</text>",
			        "",
			        [Rk], ASC
			    )
			
			VAR _OtherLblY = _MT + _CH + 5
			VAR _OtherXLabel =
			    "<text transform='rotate(-45 " & FORMAT( _OtherXC, "0.0" ) & " " & FORMAT( _OtherLblY, "0" ) & ")'
			           x='"         & FORMAT( _OtherXC,  "0.0" ) & "'
			           y='"         & FORMAT( _OtherLblY, "0"  ) & "'
			           font-size='9' fill='#6b7280' text-anchor='end'>Others</text>"
			
			-- ══ STEP J · LEFT Y-AXIS (Revenue) ════════════════════════════════
			VAR _MaxRevM = INT( _MaxRevScl / 1000000 ) + 1
			VAR _YStep   = IF( _MaxRevM <= 10, 2, IF( _MaxRevM <= 25, 5, 10 ) )
			
			VAR _LeftAxis =
			    CONCATENATEX(
			        FILTER(
			            ADDCOLUMNS(
			                GENERATESERIES( 0, 7, 1 ),
			                "VM", [Value] * _YStep,
			                "YP", _MT + _CH - ( [Value] * _YStep * 1000000 / _MaxRevScl ) * _CH
			            ),
			            [VM] * 1000000 <= _MaxRevScl
			        ),
			        "<text x='" & FORMAT( _ML - 4, "0"   ) & "'
			               y='" & FORMAT( [YP] + 3, "0.0" ) & "'
			               font-size='9' fill='#9ca3af' text-anchor='end'>"
			        & FORMAT( [VM], "0" ) & "M</text>"
			        & "<line x1='" & FORMAT( _ML,       "0"   ) & "' y1='" & FORMAT( [YP], "0.0" ) & "'
			                x2='" & FORMAT( _ML + _CW,  "0"   ) & "' y2='" & FORMAT( [YP], "0.0" ) & "'
			                stroke='#f3f4f6' stroke-width='1'/>",
			        "",
			        [Value], ASC
			    )
			
			-- ══ STEP K · RIGHT Y-AXIS (Cumulative %) ══════════════════════════
			VAR _RightAxis =
			    CONCATENATEX(
			        ADDCOLUMNS( GENERATESERIES( 0, 5, 1 ), "Pct", [Value] * 20 ),
			        VAR _YR = _MT + _CH - ( [Pct] / 100 ) * _CH
			        RETURN
			        "<text x='" & FORMAT( _ML + _CW + 4, "0"   ) & "'
			               y='" & FORMAT( _YR + 3,        "0.0" ) & "'
			               font-size='9' fill='#d97706' text-anchor='start'>"
			        & FORMAT( [Pct], "0" ) & "%</text>",
			        "",
			        [Value], ASC
			    )
			
			-- ══ STEP L · 80% THRESHOLD LINE ═══════════════════════════════════
			VAR _80Y =  _MT + _CH - ( 0.80 * _CH )
			VAR _ThreshLine =
			    "<line x1='" & FORMAT( _ML,      "0"   ) & "' y1='" & FORMAT( _80Y, "0.0" ) & "'
			           x2='" & FORMAT( _ML + _CW,"0"   ) & "' y2='" & FORMAT( _80Y, "0.0" ) & "'
			           stroke='#ef4444' stroke-width='1.5' stroke-dasharray='5,3' opacity='0.8'/>"
			  & "<text x='" & FORMAT( _ML + _CW - 2, "0"   ) & "'
			           y='" & FORMAT( _80Y - 4,        "0.0" ) & "'
			           font-size='9' font-weight='600' fill='#ef4444' text-anchor='end'>80%</text>"
			
			-- ══ STEP M · FOOTER ═══════════════════════════════════════════════
			VAR _FooterTxt =
			    "Top " & FORMAT( _ParetoSKUs, "0" ) & " SKUs generate 80% of revenue — remaining "
			    & FORMAT( _RemCount, "0" ) & " SKUs contribute only 20%, signalling portfolio rationalisation opportunity"
			
			-- ══ ASSEMBLE ══════════════════════════════════════════════════════
			RETURN
			"<div style='font-family:Segoe UI,sans-serif;padding:12px 14px;
			             background:#fff;border-radius:6px;box-sizing:border-box;'>
			
			  <div style='display:flex;justify-content:space-between;
			              align-items:baseline;margin-bottom:8px;'>
			    <span style='font-size:11px;font-weight:700;
			                 letter-spacing:.07em;color:#1a1a1a;'>
			      Revenue Pareto · Top SKUs
			    </span>
			    <span style='font-size:10px;color:#aaa;'>Cumulative % revenue — AED</span>
			  </div>
			
			  <svg width='100%'
			       viewBox='0 0 " & FORMAT( _SVGW, "0" ) & " " & FORMAT( _SVGH, "0" ) & "'
			       xmlns='http://www.w3.org/2000/svg'>
			
			    " & _LeftAxis & "
			    " & _Bars & "
			    " & _OtherBar & "
			
			    <polyline points='" & _FullLine & "'
			      fill='none' stroke='#d97706' stroke-width='2'/>
			
			    " & _Circles & "
			    " & _OtherCircle & "
			    " & _ThreshLine & "
			    " & _RightAxis & "
			
			    <line x1='" & FORMAT( _ML,      "0" ) & "' y1='" & FORMAT( _MT + _CH, "0" ) & "'
			          x2='" & FORMAT( _ML + _CW,"0" ) & "' y2='" & FORMAT( _MT + _CH, "0" ) & "'
			          stroke='#e5e7eb' stroke-width='1'/>
			
			    " & _XLabels & "
			    " & _OtherXLabel & "
			
			  </svg>
			
			  <div style='margin-top:4px;padding:5px 10px;background:#fef2f2;
			              border-left:3px solid #ef4444;font-size:10px;color:#555;
			              border-radius:0 3px 3px 0;'>
			    ✦ " & _FooterTxt & "
			  </div>
			</div>"
		lineageTag: aafca3c7-cf80-44d4-8a2c-24b64d742d66

	measure KPI_ActiveSKUs =
			
			
			VAR _CY = MAXX( ALL( Dim_Date ), Dim_Date[year] )
			
			-- Active SKUs: distinct products with any sales (all time)
			VAR _ActiveCount =
			    COUNTROWS(
			        FILTER(
			            VALUES( Dim_Product[Product_id] ),
			            CALCULATE( SUM( Fact[Sales Amount] ) ) > 0
			        )
			    )
			
			-- Total SKUs in master list
			VAR _TotalCount = DISTINCTCOUNT( Dim_Product[Product_id] )
			
			-- New launches: in current year but absent in previous year
			VAR _CYSKUs =
			    CALCULATETABLE( VALUES( Dim_Product[Product_id] ), Dim_Date[year] = _CY )
			VAR _PYSKUs =
			    CALCULATETABLE( VALUES( Dim_Product[Product_id] ), Dim_Date[year] = _CY - 1 )
			VAR _NewLaunches = COUNTROWS( EXCEPT( _CYSKUs, _PYSKUs ) )
			
			RETURN
			"<div style='font-family:Segoe UI,Arial,sans-serif;
			background:#FFFFFF;
			border-top:3px solid #2F5F8F;
			border-radius:10px;
			padding:16px 18px;
			height:90%;
			box-sizing:border-box;'>
			
			<div style='font-size:10px;font-weight:700;letter-spacing:1px;
			color:#67726C;text-transform:uppercase;margin-bottom:8px;'>
			ACTIVE SKUs
			</div>
			
			<div style='font-size:28px;font-weight:700;color:#1C2624;line-height:1;'>
			" & FORMAT( _ActiveCount, "0" ) & "
			<span style='font-size:16px;font-weight:500;color:#67726C;'>
			/ " & FORMAT( _TotalCount, "0" ) & "
			</span>
			</div>
			
			<div style='font-size:11px;color:#67726C;margin:8px 0 10px;'>
			active vs total product universe
			</div>
			
			<div style='display:inline-block;font-size:11px;font-weight:600;
			padding:3px 9px;border-radius:6px;
			background:#E7F2EB;color:#2C5C3C;'>
			▲ " & FORMAT( _NewLaunches, "0" ) & " new launches
			</div>
			</div>"
		lineageTag: a3ca5c61-b33a-4c47-a28e-dd03f7a1a25d

	measure KPI_ParetoThreshold =
			
			
			-- Always shows all-time figure regardless of slicers
			VAR _AllSKU =
			    FILTER(
			        ADDCOLUMNS(
			            VALUES( Dim_Product[Product_id] ),
			            "Rev", CALCULATE(
			                SUM( Fact[Sales Amount] ),
			                REMOVEFILTERS( Dim_Date ),
			                REMOVEFILTERS( Dim_region )
			            )
			        ),
			        NOT ISBLANK( [Rev] ) && [Rev] > 0
			    )
			
			VAR _TotalRev   = SUMX( _AllSKU, [Rev] )
			VAR _TotalCount = COUNTROWS( _AllSKU )
			
			VAR _AllRanked =
			    ADDCOLUMNS(
			        _AllSKU,
			        "Rk", RANKX( _AllSKU, [Rev],, DESC, Dense )
			    )
			
			VAR _AllCumul =
			    ADDCOLUMNS(
			        _AllRanked,
			        "CumRev",
			        VAR _R = [Rk]
			        RETURN SUMX( FILTER( _AllRanked, [Rk] <= _R ), [Rev] )
			    )
			
			VAR _ParetoN  = MINX( FILTER( _AllCumul, [CumRev] >= _TotalRev * 0.80 ), [Rk] )
			VAR _RestCount = _TotalCount - _ParetoN
			VAR _RestPct  = FORMAT( _RestCount / _TotalCount * 100, "0" ) & "%"
			
			RETURN
			"<div style='font-family:Segoe UI,Arial,sans-serif;
			background:#FFFFFF;
			border-top:3px solid #2F5F8F;
			border-radius:10px;
			padding:16px 18px;
			height:90%;
			box-sizing:border-box;'>
			
			<div style='font-size:10px;font-weight:700;letter-spacing:1px;
			color:#67726C;text-transform:uppercase;margin-bottom:8px;'>
			PARETO THRESHOLD
			</div>
			
			<div style='font-size:28px;font-weight:700;color:#1C2624;line-height:1;'>
			" & FORMAT( _ParetoN, "0" ) & "
			<span style='font-size:18px;font-weight:600;'> SKUs</span>
			</div>
			
			<div style='font-size:11px;color:#67726C;margin:8px 0 10px;'>
			drive 80% of total portfolio revenue
			</div>
			
			<div style='display:inline-block;font-size:11px;font-weight:600;
			padding:3px 9px;border-radius:6px;
			background:#f3f4f6;color:#374151;'>
			80% of revenue
			</div>
			</div>"
		lineageTag: ad7275ff-871d-4449-8b8a-d007daa814d9

	measure KPI_RevenueGrowthMoM =
			
			
			-- Latest month with actual sales
			VAR _LastDate =
			    MAXX(
			        FILTER(
			            ALL(Fact),
			            NOT ISBLANK(Fact[Sales Amount])
			        ),
			        Fact[date]
			    )
			
			VAR _CY = YEAR(_LastDate)
			VAR _CM = MONTH(_LastDate)
			
			VAR _PM = IF(_CM = 1, 12, _CM - 1)
			VAR _PY = IF(_CM = 1, _CY - 1, _CY)
			
			VAR _CurRev =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        FILTER(
			            ALL(Dim_Date),
			            Dim_Date[year] = _CY
			                && Dim_Date[month] = _CM
			        )
			    )
			
			VAR _PrevRev =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        FILTER(
			            ALL(Dim_Date),
			            Dim_Date[year] = _PY
			                && Dim_Date[month] = _PM
			        )
			    )
			
			VAR _Effect = _CurRev - _PrevRev
			VAR _EffectM = DIVIDE(_Effect, 1000000)
			
			VAR _GrowthPct =
			    DIVIDE(_Effect, _PrevRev)
			
			VAR _Color =
			    IF(_Effect >= 0, "#2C5C3C", "#C27C00")
			
			VAR _Bg =
			    IF(_Effect >= 0, "#E7F2EB", "#F7E8B5")
			
			VAR _Arrow =
			    IF(_Effect >= 0, "↑", "↓")
			
			VAR _Sign =
			    IF(_Effect >= 0, "+", "-")
			
			VAR _MonthName =
			    SWITCH(
			        _CM,
			        1,"Jan",2,"Feb",3,"Mar",4,"Apr",
			        5,"May",6,"Jun",7,"Jul",8,"Aug",
			        9,"Sep",10,"Oct",11,"Nov",12,"Dec"
			    )
			
			VAR _PrevMonthName =
			    SWITCH(
			        _PM,
			        1,"Jan",2,"Feb",3,"Mar",4,"Apr",
			        5,"May",6,"Jun",7,"Jul",8,"Aug",
			        9,"Sep",10,"Oct",11,"Nov",12,"Dec"
			    )
			
			RETURN
			
			"<div style='font-family:Segoe UI,Arial,sans-serif;
			background:#FFFFFF;
			border-top:3px solid #2F5F8F;
			border-radius:10px;
			padding:16px 18px;
			height:90%;
			box-sizing:border-box;'>
			
			<div style='font-size:10px;font-weight:700;letter-spacing:1px;
			color:#67726C;text-transform:uppercase;margin-bottom:8px;'>
			REVENUE GROWTH MOM
			</div>
			
			<div style='font-size:28px;font-weight:700;color:#1C2624;line-height:1;'>
			" & _Sign & FORMAT(ABS(_EffectM), "0.0") & "M
			</div>
			
			<div style='font-size:11px;color:#67726C;margin:8px 0 10px;'>
			revenue change " & _PrevMonthName & " → " & _MonthName & " " & FORMAT(_CY,"0") & "
			</div>
			
			<div style='display:inline-block;font-size:11px;font-weight:600;
			padding:3px 9px;border-radius:6px;
			background:" & _Bg & ";color:" & _Color & ";'>
			" & _Arrow & " " & FORMAT(ABS(_GrowthPct),"0.0%") & " vs last month
			</div>
			
			</div>"
		lineageTag: f4c1854b-f011-4322-a233-bb2df773cb7f

	measure 'Avg Visibility Score' =
			
			DIVIDE(
			    SUM( Fact[stock_available] ),
			    SUM( Fact[stock_available] ) + SUM( Fact[units_sold] )
			)
		lineageTag: e5bb8503-d7a0-477a-9e0c-bf29f931ce95

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure KPI_AvgVisibilityScore =
			
			
			VAR _Score  = [Avg Visibility Score]
			VAR _Target = 0.07          -- adjust to your actual target
			
			VAR _Diff   = _Score - _Target
			VAR _Color  = IF( _Diff >= 0, "#2C5C3C", "#C27C00" )
			VAR _Bg     = IF( _Diff >= 0, "#E7F2EB", "#F7E8B5" )
			VAR _Arrow  = IF( _Diff >= 0, "▲", "▼" )
			VAR _Sign   = IF( _Diff >= 0, "+", "" )   -- negative already has minus sign
			
			RETURN
			"<div style='font-family:Segoe UI,Arial,sans-serif;
			background:#FFFFFF;
			border-top:3px solid #2F5F8F;
			border-radius:10px;
			padding:16px 18px;
			height:90%;
			box-sizing:border-box;'>
			
			<div style='font-size:10px;font-weight:700;letter-spacing:1px;
			color:#67726C;text-transform:uppercase;margin-bottom:8px;'>
			AVG VISIBILITY SCORE
			</div>
			
			<div style='font-size:28px;font-weight:700;color:#1C2624;line-height:1;'>
			" & FORMAT( _Score, "0.000" ) & "
			</div>
			
			<div style='font-size:11px;color:#67726C;margin:8px 0 10px;'>
			avg shelf fill rate, all outlet types
			</div>
			
			<div style='display:inline-block;font-size:11px;font-weight:600;
			padding:3px 9px;border-radius:6px;
			background:" & _Bg & ";color:" & _Color & ";'>
			" & _Arrow & " " & _Sign & FORMAT( _Diff, "0.000" ) & " VS TARGET " & FORMAT( _Target, "0.000" ) & "
			</div>
			</div>"
		lineageTag: c8006932-3600-44c1-a2f0-183df45f813e

	measure HTML_ItemVisibilityByOutlet =
			
			
			-- ══ CONFIG ════════════════════════════════════════════════════
			VAR _Target   = 0.07      -- dashed target line
			VAR _MaxScale = 0.12      -- x-axis ceiling (gives breathing room)
			VAR _BarMaxW  = 380       -- max bar pixel width
			VAR _BarH     = 18        -- bar height
			VAR _LabelW   = 105       -- left label column width
			VAR _RowGap   = 30        -- vertical spacing between rows
			VAR _ValColW  = 44        -- right-side score label column
			
			VAR _SVGW = _LabelW + _BarMaxW + _ValColW + 10
			
			-- ══ STEP A · SCORE PER OUTLET TYPE ═══════════════════════════
			-- Dim_outlet[channel] holds outlet types (Hypermarket, Supermarket etc.)
			-- CALCULATE filters Fact rows through the Dim_outlet relationship
			VAR _Data =
			    ADDCOLUMNS(
			        FILTER(
			            VALUES( Dim_outlet[channel] ),
			            NOT ISBLANK( Dim_outlet[channel] )
			        ),
			        "Score",
			        CALCULATE(
			            DIVIDE(
			                SUM( Fact[stock_available] ),
			                SUM( Fact[stock_available] ) + SUM( Fact[units_sold] )
			            )
			        )
			    )
			
			-- Remove outlet types with no data
			VAR _DataClean = FILTER( _Data, NOT ISBLANK( [Score] ) && [Score] > 0 )
			
			-- ══ STEP B · RANK WORST → BEST (worst at top, best at bottom) ═══
			-- Row 1 (y=top) = worst performer so it reads like the screenshot
			VAR _Ranked =
			    ADDCOLUMNS(
			        _DataClean,
			        "Rk", RANKX( _DataClean, [Score],, ASC, Dense )
			    )
			
			VAR _NumRows = COUNTROWS( _DataClean )
			VAR _SVGH    = _NumRows * _RowGap + 32
			
			-- ══ STEP C · ENRICH: positions, colors, labels ════════════════
			VAR _Enriched =
			    ADDCOLUMNS(
			        _Ranked,
			        "RowY",  ( [Rk] - 1 ) * _RowGap + 4,
			        "TextY", ( [Rk] - 1 ) * _RowGap + 4 + _BarH - 5,
			        "BarW",  DIVIDE( [Score], _MaxScale ) * _BarMaxW,
			
			        -- RAG: green if at/above target, amber if within 30% below, red otherwise
			        "Color",
			        IF( [Score] >= _Target,              "#166534",
			        IF( [Score] >= _Target * 0.70,       "#ca8a04",
			                                             "#dc2626" ) )
			    )
			
			-- ══ STEP D · BUILD BAR ROWS ════════════════════════════════════
			VAR _Bars =
			    CONCATENATEX(
			        _Enriched,
			
			        -- Outlet type label (left side)
			        "<text x='0'
			               y='" & FORMAT( [TextY], "0" ) & "'
			               font-size='10' font-weight='600'
			               fill='#374151'>" & [channel] & "</text>"
			
			        -- Background track
			        & "<rect x='" & FORMAT( _LabelW, "0" ) & "'
			                y='" & FORMAT( [RowY],   "0" ) & "'
			                width='" & FORMAT( _BarMaxW, "0" ) & "'
			                height='" & FORMAT( _BarH, "0" ) & "'
			                fill='#f3f4f6' rx='3'/>"
			
			        -- Coloured bar
			        & "<rect x='" & FORMAT( _LabelW, "0" ) & "'
			                y='" & FORMAT( [RowY],   "0" ) & "'
			                width='" & FORMAT( [BarW], "0.1" ) & "'
			                height='" & FORMAT( _BarH,   "0" ) & "'
			                fill='" & [Color] & "' rx='3'/>"
			
			        -- Score value to right of bar
			        & "<text x='" & FORMAT( _LabelW + _BarMaxW + 6, "0" ) & "'
			                y='" & FORMAT( [TextY], "0" ) & "'
			                font-size='10' font-weight='600'
			                fill='#374151'>" & FORMAT( [Score], "0.000" ) & "</text>",
			
			        "",
			        [Rk], ASC      -- worst (rank 1) at top
			    )
			
			-- ══ STEP E · X-AXIS LABELS ════════════════════════════════════
			-- 0.00, 0.02, 0.04, 0.06, 0.08, 0.10 (every 0.02)
			VAR _XAxis =
			    CONCATENATEX(
			        ADDCOLUMNS(
			            GENERATESERIES( 0, 6, 1 ),
			            "XV",  [Value] * 0.02,
			            "XP",  _LabelW + DIVIDE( [Value] * 0.02, _MaxScale ) * _BarMaxW
			        ),
			        "<text x='"  & FORMAT( [XP], "0.0" ) & "'
			               y='"  & FORMAT( _SVGH - 4, "0" ) & "'
			               text-anchor='middle'
			               font-size='9' fill='#9ca3af'>"
			        & FORMAT( [XV], "0.00" ) & "</text>",
			        "",
			        [Value], ASC
			    )
			
			-- ══ STEP F · TARGET DASHED LINE ════════════════════════════════
			VAR _TargetX =
			    FORMAT( _LabelW + DIVIDE( _Target, _MaxScale ) * _BarMaxW, "0.1" )
			
			VAR _TargetLine =
			    "<line x1='" & _TargetX & "' y1='0'
			           x2='" & _TargetX & "' y2='" & FORMAT( _SVGH - 16, "0" ) & "'
			           stroke='#9ca3af' stroke-width='1.5' stroke-dasharray='4,3'/>"
			  & "<text x='" & _TargetX & "'
			           y='8'
			           text-anchor='middle'
			           font-size='9' fill='#9ca3af'>target</text>"
			
			-- ══ STEP G · DYNAMIC FOOTER ════════════════════════════════════
			-- Compares worst outlet vs best outlet scores dynamically
			VAR _BestOutlet  = MINX( FILTER( _Enriched, [Score] = MAXX( _Enriched, [Score] ) ), [channel] )
			VAR _WorstOutlet = MINX( FILTER( _Enriched, [Score] = MINX( _Enriched, [Score] ) ), [channel] )
			VAR _BestScore   = MAXX( _Enriched, [Score] )
			VAR _WorstScore  = MINX( _Enriched, [Score] )
			VAR _Ratio       = FORMAT( DIVIDE( _BestScore, _WorstScore ), "0.0" )
			
			VAR _FooterTxt =
			    _WorstOutlet & " visibility (" & FORMAT( _WorstScore, "0.000" ) & ") is "
			    & _Ratio & "× below " & _BestOutlet
			    & " — planogram compliance action required"
			
			-- ══ ASSEMBLE ══════════════════════════════════════════════════
			RETURN
			"<div style='font-family:Segoe UI,sans-serif;padding:12px 14px;
			             background:#fff;border-radius:6px;box-sizing:border-box;'>
			
			  <!-- HEADER -->
			  <div style='display:flex;justify-content:space-between;
			              align-items:baseline;margin-bottom:10px;'>
			    <span style='font-size:11px;font-weight:700;
			                 letter-spacing:.07em;color:#1a1a1a;'>
			      ITEM VISIBILITY SCORE · BY OUTLET TYPE
			    </span>
			    <span style='font-size:10px;color:#aaa;'>Avg shelf fill rate</span>
			  </div>
			
			  <!-- CHART -->
			  <svg width='100%'
			       viewBox='0 0 " & FORMAT( _SVGW, "0" ) & " " & FORMAT( _SVGH, "0" ) & "'
			       xmlns='http://www.w3.org/2000/svg'>
			
			    " & _Bars & "
			    " & _TargetLine & "
			    " & _XAxis & "
			
			    <!-- X-axis baseline -->
			    <line x1='" & FORMAT( _LabelW, "0" ) & "'
			          y1='" & FORMAT( _SVGH - 16, "0" ) & "'
			          x2='" & FORMAT( _LabelW + _BarMaxW, "0" ) & "'
			          y2='" & FORMAT( _SVGH - 16, "0" ) & "'
			          stroke='#e5e7eb' stroke-width='1'/>
			
			  </svg>
			
			  <!-- FOOTER CALLOUT -->
			  <div style='margin-top:4px;padding:5px 10px;background:#fef2f2;
			              border-left:3px solid #dc2626;font-size:10px;color:#555;
			              border-radius:0 3px 3px 0;'>
			    ✦ " & _FooterTxt & "
			  </div>
			</div>"
		lineageTag: d794da79-c2d9-4c03-8f18-52b6a4fa7816

	measure HTML_RevenueBridge = ```
			
			
			VAR OctRevenue = 8.2
			VAR Volume     = 0.8
			VAR Price      = 0.8
			VAR Mix        = -0.2
			VAR Promo      = -0.2
			
			VAR NovRevenue = OctRevenue + Volume + Price + Mix + Promo
			
			-- Running totals
			VAR Run1 = OctRevenue
			VAR Run2 = Run1 + Volume
			VAR Run3 = Run2 + Price
			VAR Run4 = Run3 + Mix
			VAR Run5 = Run4 + Promo
			
			-- Chart setup
			VAR YMin = 7.5
			VAR YMax = 10.5
			
			VAR ChartHeight = 260
			VAR ChartWidth  = 620
			
			VAR Scale =
			DIVIDE( ChartHeight , YMax - YMin )
			
			-- X Positions
			VAR X1 = 55
			VAR X2 = 150
			VAR X3 = 245
			VAR X4 = 340
			VAR X5 = 435
			VAR X6 = 530
			
			VAR BarWidth = 44
			
			-- Colors
			VAR TotalColor = "#2F6FAE"
			VAR Positive   = "#0E7C66"
			VAR Negative   = "#D9534F"
			VAR Connector  = "#D1D5DB"
			
			-- Heights
			VAR H_Oct =
			( OctRevenue - YMin ) * Scale
			
			VAR H_Vol =
			ABS( Volume ) * Scale
			
			VAR H_Price =
			ABS( Price ) * Scale
			
			VAR H_Mix =
			ABS( Mix ) * Scale
			
			VAR H_Promo =
			ABS( Promo ) * Scale
			
			VAR H_Nov =
			( NovRevenue - YMin ) * Scale
			
			-- Y coordinates
			VAR Y_Oct =
			ChartHeight - H_Oct
			
			VAR Y_Vol =
			ChartHeight - MAX( Run1 , Run2 ) * Scale + YMin * Scale
			
			VAR Y_Price =
			ChartHeight - MAX( Run2 , Run3 ) * Scale + YMin * Scale
			
			VAR Y_Mix =
			ChartHeight - MAX( Run3 , Run4 ) * Scale + YMin * Scale
			
			VAR Y_Promo =
			ChartHeight - MAX( Run4 , Run5 ) * Scale + YMin * Scale
			
			VAR Y_Nov =
			ChartHeight - H_Nov
			
			VAR FooterText =
			"Revenue increased from "
			& FORMAT( OctRevenue , "$0.0M" )
			& " to "
			& FORMAT( NovRevenue , "$0.0M" )
			& " driven primarily by Volume (+"
			& FORMAT( Volume , "0.0" )
			& "M) and Price (+"
			& FORMAT( Price , "0.0" )
			& "M)."
			
			RETURN
			
			"<div style='font-family:Segoe UI,sans-serif;
			          padding:12px 14px;
			          background:#fff;
			          border-radius:6px;'>
			
			<div style='display:flex;
			            justify-content:space-between;
			            margin-bottom:10px;'>
			
			<span style='font-size:11px;
			          font-weight:700;
			          letter-spacing:.07em;
			          color:#1a1a1a;'>
			REVENUE BRIDGE · OCT → NOV </span>
			
			<span style='font-size:10px;
			          color:#9ca3af;'>
			Impact Analysis ($M) </span>
			
			</div>
			
			<svg viewBox='0 0 620 300'
			  width='100%'
			  xmlns='http://www.w3.org/2000/svg'>
			
			<!-- CONNECTORS -->
			
			<line x1='" & (X1+22) & "'
			   y1='" & Y_Oct & "'
			   x2='" & X2 & "'
			   y2='" & Y_Oct & "'
			   stroke='" & Connector & "'
			   stroke-width='2'/>
			
			<line x1='" & (X2+22) & "'
			   y1='" & (ChartHeight-(Run2-YMin)*Scale) & "'
			   x2='" & X3 & "'
			   y2='" & (ChartHeight-(Run2-YMin)*Scale) & "'
			   stroke='" & Connector & "'
			   stroke-width='2'/>
			
			<line x1='" & (X3+22) & "'
			   y1='" & (ChartHeight-(Run3-YMin)*Scale) & "'
			   x2='" & X4 & "'
			   y2='" & (ChartHeight-(Run3-YMin)*Scale) & "'
			   stroke='" & Connector & "'
			   stroke-width='2'/>
			
			<line x1='" & (X4+22) & "'
			   y1='" & (ChartHeight-(Run4-YMin)*Scale) & "'
			   x2='" & X5 & "'
			   y2='" & (ChartHeight-(Run4-YMin)*Scale) & "'
			   stroke='" & Connector & "'
			   stroke-width='2'/>
			
			<line x1='" & (X5+22) & "'
			   y1='" & (ChartHeight-(Run5-YMin)*Scale) & "'
			   x2='" & X6 & "'
			   y2='" & (ChartHeight-(Run5-YMin)*Scale) & "'
			   stroke='" & Connector & "'
			   stroke-width='2'/>
			
			<!-- OCT TOTAL -->
			
			<rect x='" & X1 & "'
			   y='" & Y_Oct & "'
			   width='" & BarWidth & "'
			   height='" & H_Oct & "'
			   fill='" & TotalColor & "'
			   rx='4'/>
			
			<!-- VOLUME -->
			
			<rect x='" & X2 & "'
			   y='" & Y_Vol & "'
			   width='" & BarWidth & "'
			   height='" & H_Vol & "'
			   fill='" & Positive & "'
			   rx='4'/>
			
			<!-- PRICE -->
			
			<rect x='" & X3 & "'
			   y='" & Y_Price & "'
			   width='" & BarWidth & "'
			   height='" & H_Price & "'
			   fill='" & Positive & "'
			   rx='4'/>
			
			<!-- MIX -->
			
			<rect x='" & X4 & "'
			   y='" & Y_Mix & "'
			   width='" & BarWidth & "'
			   height='" & H_Mix & "'
			   fill='" & Negative & "'
			   rx='4'/>
			
			<!-- PROMO -->
			
			<rect x='" & X5 & "'
			   y='" & Y_Promo & "'
			   width='" & BarWidth & "'
			   height='" & H_Promo & "'
			   fill='" & Negative & "'
			   rx='4'/>
			
			<!-- NOV TOTAL -->
			
			<rect x='" & X6 & "'
			   y='" & Y_Nov & "'
			   width='" & BarWidth & "'
			   height='" & H_Nov & "'
			   fill='" & TotalColor & "'
			   rx='4'/>
			
			<!-- VALUES -->
			
			<text x='" & (X1+22) & "' y='" & (Y_Oct-8) & "'
			   text-anchor='middle'
			   font-size='10'
			   font-weight='600'>
			" & FORMAT(OctRevenue,"0.0") & " </text>
			
			<text x='" & (X6+22) & "' y='" & (Y_Nov-8) & "'
			   text-anchor='middle'
			   font-size='10'
			   font-weight='600'>
			" & FORMAT(NovRevenue,"0.0") & " </text>
			
			<!-- CATEGORY LABELS -->
			
			<text x='" & (X1+22) & "' y='285' text-anchor='middle' font-size='10'>Oct</text> <text x='" & (X2+22) & "' y='285' text-anchor='middle' font-size='10'>Volume</text> <text x='" & (X3+22) & "' y='285' text-anchor='middle' font-size='10'>Price</text> <text x='" & (X4+22) & "' y='285' text-anchor='middle' font-size='10'>Mix</text> <text x='" & (X5+22) & "' y='285' text-anchor='middle' font-size='10'>Promo</text> <text x='" & (X6+22) & "' y='285' text-anchor='middle' font-size='10'>Nov</text>
			
			</svg>
			
			<div style='margin-top:4px;
			            padding:5px 10px;
			            background:#eff6ff;
			            border-left:3px solid #2563eb;
			            font-size:10px;
			            color:#555;
			            border-radius:0 3px 3px 0;'>
			
			✦ " & FooterText & "
			
			</div>
			
			</div>"
			
