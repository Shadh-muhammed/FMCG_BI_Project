	measure 'HTML - Revenue By Channel Region' = ```
			
			
			VAR CentralRetail =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-Central",
			        Fact[channel] = "Retail",
			        Dim_Date[year] = 2024
			    )
			VAR CentralDiscount =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-Central",
			        Fact[channel] = "Discount",
			        Dim_Date[year] = 2024
			    )
			VAR CentralEcom =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-Central",
			        Fact[channel] = "E-Commerce",
			        Dim_Date[year] = 2024
			    )
			VAR CentralTotal = CentralRetail + CentralDiscount + CentralEcom
			
			VAR NorthRetail =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-North",
			        Fact[channel] = "Retail",
			        Dim_Date[year] = 2024
			    )
			VAR NorthDiscount =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-North",
			        Fact[channel] = "Discount",
			        Dim_Date[year] = 2024
			    )
			VAR NorthEcom =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-North",
			        Fact[channel] = "E-Commerce",
			        Dim_Date[year] = 2024
			    )
			VAR NorthTotal = NorthRetail + NorthDiscount + NorthEcom
			
			VAR SouthRetail =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-South",
			        Fact[channel] = "Retail",
			        Dim_Date[year] = 2024
			    )
			VAR SouthDiscount =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-South",
			        Fact[channel] = "Discount",
			        Dim_Date[year] = 2024
			    )
			VAR SouthEcom =
			    CALCULATE(
			        SUM(Fact[Sales Amount]),
			        Fact[region] = "PL-South",
			        Fact[channel] = "E-Commerce",
			        Dim_Date[year] = 2024
			    )
			VAR SouthTotal = SouthRetail + SouthDiscount + SouthEcom
			
			-- Max region total → used to scale all bars proportionally
			VAR MaxVal = MAXX( { CentralTotal, NorthTotal, SouthTotal }, [Value] )
			
			-- Max bar width in pixels (adjust if your visual is wider/narrower)
			VAR BarWidth = 280
			
			-- Bar segment widths as integers
			VAR CR = INT( DIVIDE(CentralRetail,  MaxVal) * BarWidth )
			VAR CD = INT( DIVIDE(CentralDiscount, MaxVal) * BarWidth )
			VAR CE = INT( DIVIDE(CentralEcom,    MaxVal) * BarWidth )
			
			VAR NR = INT( DIVIDE(NorthRetail,    MaxVal) * BarWidth )
			VAR ND = INT( DIVIDE(NorthDiscount,  MaxVal) * BarWidth )
			VAR NE = INT( DIVIDE(NorthEcom,      MaxVal) * BarWidth )
			
			VAR SR = INT( DIVIDE(SouthRetail,    MaxVal) * BarWidth )
			VAR SD = INT( DIVIDE(SouthDiscount,  MaxVal) * BarWidth )
			VAR SE = INT( DIVIDE(SouthEcom,      MaxVal) * BarWidth )
			
			-- Dynamic insight: find region with highest E-Commerce share
			VAR CentralEcomShare = DIVIDE(CentralEcom, CentralTotal)
			VAR NorthEcomShare   = DIVIDE(NorthEcom,   NorthTotal)
			VAR SouthEcomShare   = DIVIDE(SouthEcom,   SouthTotal)
			
			VAR TopEcomRegion =
			    SWITCH(
			        TRUE(),
			        CentralEcomShare >= NorthEcomShare && CentralEcomShare >= SouthEcomShare, "Central",
			        NorthEcomShare   >= SouthEcomShare, "North",
			        "South"
			    )
			VAR TopEcomShare =
			    SWITCH(
			        TopEcomRegion,
			        "Central", CentralEcomShare,
			        "North",   NorthEcomShare,
			        SouthEcomShare
			    )
			
			RETURN
			
			"<div style='font-family:Segoe UI,Arial,sans-serif;
			padding:16px 18px;
			background:#FFFFFF;
			border-radius:10px;
			height:90%;
			box-sizing:border-box;'>
			
			<div style='display:flex;justify-content:space-between;align-items:baseline;margin-bottom:18px;'>
			<span style='font-size:10px;font-weight:700;letter-spacing:1px;color:#222;text-transform:uppercase;'>Revenue by Channel · per Region</span>
			<span style='font-size:10px;color:#aaa;'>Sales value — AED</span>
			</div>
			
			<div style='display:flex;align-items:center;margin-bottom:10px;'>
			<div style='width:52px;font-size:11px;color:#333;font-weight:500;'>Central</div>
			<div style='display:flex;height:14px;border-radius:2px;overflow:hidden;background:#f0f0f0;'>
			<div style='width:" & CR & "px;background:#1F6B4A;'></div>
			<div style='width:" & CD & "px;background:#3F8DB5;'></div>
			<div style='width:" & CE & "px;background:#D5B314;'></div>
			</div>
			<div style='margin-left:8px;font-size:11px;font-weight:700;color:#222;'>"
			& FORMAT(CentralTotal / 1000000, "0.0") & "M</div>
			</div>
			
			<div style='display:flex;align-items:center;margin-bottom:10px;'>
			<div style='width:52px;font-size:11px;color:#333;font-weight:500;'>North</div>
			<div style='display:flex;height:14px;border-radius:2px;overflow:hidden;background:#f0f0f0;'>
			<div style='width:" & NR & "px;background:#1F6B4A;'></div>
			<div style='width:" & ND & "px;background:#3F8DB5;'></div>
			<div style='width:" & NE & "px;background:#D5B314;'></div>
			</div>
			<div style='margin-left:8px;font-size:11px;font-weight:700;color:#222;'>"
			& FORMAT(NorthTotal / 1000000, "0.0") & "M</div>
			</div>
			
			<div style='display:flex;align-items:center;margin-bottom:16px;'>
			<div style='width:52px;font-size:11px;color:#333;font-weight:500;'>South</div>
			<div style='display:flex;height:14px;border-radius:2px;overflow:hidden;background:#f0f0f0;'>
			<div style='width:" & SR & "px;background:#1F6B4A;'></div>
			<div style='width:" & SD & "px;background:#3F8DB5;'></div>
			<div style='width:" & SE & "px;background:#D5B314;'></div>
			</div>
			<div style='margin-left:8px;font-size:11px;font-weight:700;color:#222;'>"
			& FORMAT(SouthTotal / 1000000, "0.0") & "M</div>
			</div>
			
			<div style='display:flex;gap:16px;font-size:10px;color:#555;margin-bottom:12px;'>
			<span><span style='color:#1F6B4A;font-size:13px;'>■</span> Retail</span>
			<span><span style='color:#3F8DB5;font-size:13px;'>■</span> Discount</span>
			<span><span style='color:#D5B314;font-size:13px;'>■</span> E-Commerce</span>
			</div>
			
			<div style='border:1px solid #C3E0CC;background:#EDF7EF;padding:6px 9px;
			font-size:10px;border-radius:4px;color:#2E6D48;font-weight:500;'>
			📌 E-Commerce highest share in " & TopEcomRegion & " (" &
			FORMAT(TopEcomShare, "0%") &
			") — signals digital-first behaviour shift
			</div>
			
			</div>"
			
			```
