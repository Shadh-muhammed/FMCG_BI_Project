	measure 'Momentum %' =
			
			DIVIDE(
			    [Units This Month] - [Units Prior Month],
			    [Units Prior Month]
			)
		lineageTag: 5e001419-c5fe-478b-bf31-f3be1bfef93d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Momentum Table Card' =
			
			VAR MomentumBySKU = ADDCOLUMNS(VALUES(Dim_Product[sku]), "@M", CALCULATE([Momentum %]))
			VAR TopAccel = TOPN(2, MomentumBySKU, [@M], DESC)
			VAR TopDecel = TOPN(2, MomentumBySKU, [@M], ASC)
			VAR TopAccelBest = MAXX(TopAccel, [@M])
			VAR TopDecelWorst = MINX(TopDecel, [@M])
			VAR AccelRows =
			    CONCATENATEX(
			        TopAccel,
			        VAR SKUName = [sku]
			        VAR MVal = [@M]
			        VAR ActionText = IF(MVal = TopAccelBest, "expand distro", "increase stock")
			        RETURN
			        "<tr><td style='padding:5px 0;color:#1f6b45'>&#9650; " & SKUName & "</td><td style='text-align:right;color:#1a1a1a'>" & FORMAT(MVal, "+0.0%;-0.0%") & "</td><td style='text-align:right;color:#6b6b63'>" & ActionText & "</td></tr>",
			        "", [@M], DESC
			    )
			VAR DecelRows =
			    CONCATENATEX(
			        TopDecel,
			        VAR SKUName = [sku]
			        VAR MVal = [@M]
			        VAR ActionText = IF(MVal = TopDecelWorst, "review promo", "reduce SKU count")
			        RETURN
			        "<tr><td style='padding:5px 0;color:#b23b3b'>&#9660; " & SKUName & "</td><td style='text-align:right;color:#1a1a1a'>" & FORMAT(MVal, "+0.0%;-0.0%") & "</td><td style='text-align:right;color:#6b6b63'>" & ActionText & "</td></tr>",
			        "", [@M], ASC
			    )
			VAR TopAccelSKU = MAXX(TOPN(1, TopAccel, [@M], DESC), [sku])
			VAR TopAccelPromoLift = CALCULATE([Promo Lift %], Dim_Product[sku] = TopAccelSKU)
			VAR TopAccelDip = CALCULATE([PostPromoDip %], Dim_Product[sku] = TopAccelSKU)
			VAR InsightText =
			    TopAccelSKU & " spiked " & FORMAT(TopAccelPromoLift, "0%") &
			    " during promo but ran " & FORMAT(ABS(TopAccelDip), "0%") &
			    IF(TopAccelDip < 0, " below", " above") & " baseline for the 4 weeks after — " &
			    IF(TopAccelDip < 0, "classic pantry loading, volume borrowed not incremental.", "sustained lift, incremental volume likely.")
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:14px;font-family:sans-serif'>" &
			"<div style='font-size:12px;font-weight:600;color:#1a1a1a;margin-bottom:10px'>Momentum leaders &amp; laggards</div>" &
			"<table style='width:100%;font-size:10.5px;border-collapse:collapse'>" &
			"<tr style='color:#9a9a92'><td style='padding:4px 0'>SKU</td><td style='text-align:right'>momentum</td><td style='text-align:right'>action</td></tr>" &
			AccelRows & DecelRows &
			"</table>" &
			"<div style='background:#fbe4e4;border-radius:4px;padding:8px 10px;margin-top:10px;font-size:10.5px;color:#8a2f2f;line-height:1.5'>&#10022; " &
			InsightText & "</div></div>"
		lineageTag: e5310e9c-3341-4eb1-8c58-e4429f0aa08b

	measure 'Stockout Risk SKU Count' = ```
			
			VAR SKUs = VALUES(Dim_Product[sku])
			VAR StockThreshold = PERCENTILEX.INC(SKUs, CALCULATE(AVERAGE(Fact[stock_available])), 0.25)
			VAR DemandThreshold = PERCENTILEX.INC(SKUs, CALCULATE([Avg Units Sold]), 0.60)
			RETURN
			COUNTX(
			    FILTER(SKUs, CALCULATE(AVERAGE(Fact[stock_available])) <= StockThreshold && CALCULATE([Avg Units Sold]) >= DemandThreshold),
			    Dim_Product[sku]
			)
			
			```
		formatString: 0
