	measure 'Forecast Trend %' =
			
			VAR LastFactDate = MAX(Fact[date])
			VAR Last4Wk =
			    CALCULATE(
			        [Units This Month],
			        Fact[date] > LastFactDate - 28 && Fact[date] <= LastFactDate
			    )
			VAR Prior4Wk =
			    CALCULATE(
			        [Units This Month],
			        Fact[date] > LastFactDate - 56 && Fact[date] <= LastFactDate - 28
			    )
			RETURN
			DIVIDE(Last4Wk - Prior4Wk, Prior4Wk)
		lineageTag: a0d5bcb5-9790-4cfc-9ce3-fc4cee90afcc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'KPI Card Promo ROI' =
			
			VAR ROI = [Overall Promo ROI]
			VAR IsGood = ROI >= 1
			VAR BadgeColor = IF(IsGood, "#1f6b45", "#b23b3b")
			VAR BadgeBg = IF(IsGood, "#e2f0e5", "#fbe4e4")
			VAR BadgeText = IF(IsGood, "&#9650; vs baseline", "&#9660; below baseline")
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:12px 14px;font-family:sans-serif'>" &
			"<div style='font-size:10px;letter-spacing:0.05em;color:#8a8a82;text-transform:uppercase'>Overall promo ROI</div>" &
			"<div style='font-size:22px;font-weight:600;color:#1a1a1a;margin-top:4px'>" & FORMAT(ROI, "0.0") & "x</div>" &
			"<div style='display:inline-block;margin-top:6px;font-size:10px;color:" & BadgeColor & ";background:" & BadgeBg & ";padding:2px 7px;border-radius:4px'>" & BadgeText & "</div>" &
			"</div>"
		lineageTag: b63a114d-a0f4-4421-8910-ff36aa5f6219

	measure 'KPI Card Promo Frequency' =
			
			VAR Freq = [Promo Frequency %]
			VAR IsOverPromoted = Freq > 0.30
			VAR BadgeColor = IF(IsOverPromoted, "#a3641f", "#1f6b45")
			VAR BadgeBg = IF(IsOverPromoted, "#faf1e0", "#e2f0e5")
			VAR BadgeText = IF(IsOverPromoted, "over-promoted", "healthy mix")
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:12px 14px;font-family:sans-serif'>" &
			"<div style='font-size:10px;letter-spacing:0.05em;color:#8a8a82;text-transform:uppercase'>Promo frequency</div>" &
			"<div style='font-size:22px;font-weight:600;color:#1a1a1a;margin-top:4px'>" & FORMAT(Freq, "0%") & "</div>" &
			"<div style='display:inline-block;margin-top:6px;font-size:10px;color:" & BadgeColor & ";background:" & BadgeBg & ";padding:2px 7px;border-radius:4px'>" & BadgeText & "</div>" &
			"</div>"
		lineageTag: 13ed4edc-6dcf-4bae-84e4-76f4d5511265

	measure 'KPI Card Stockout Risk' =
			
			VAR RiskCount = [Stockout Risk SKU Count]
			VAR HasRisk = RiskCount > 0
			VAR BadgeColor = IF(HasRisk, "#b23b3b", "#1f6b45")
			VAR BadgeBg = IF(HasRisk, "#fbe4e4", "#e2f0e5")
			VAR BadgeText = IF(HasRisk, "action required", "no risk")
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:12px 14px;font-family:sans-serif'>" &
			"<div style='font-size:10px;letter-spacing:0.05em;color:#8a8a82;text-transform:uppercase'>SKUs at stockout risk</div>" &
			"<div style='font-size:22px;font-weight:600;color:#1a1a1a;margin-top:4px'>" & RiskCount & "</div>" &
			"<div style='display:inline-block;margin-top:6px;font-size:10px;color:" & BadgeColor & ";background:" & BadgeBg & ";padding:2px 7px;border-radius:4px'>" & BadgeText & "</div>" &
			"</div>"
		lineageTag: 3525fb8f-3862-4d5e-a999-6aaa3f935cd9

	measure 'KPI Card Forecast Trend' =
			
			VAR Trends = [Forecast Trend %]
			VAR IsUp = Trends >= 0
			VAR BadgeColor = IF(IsUp, "#1f6b45", "#b23b3b")
			VAR BadgeBg = IF(IsUp, "#e2f0e5", "#fbe4e4")
			VAR BadgeText = IF(IsUp, "&#9650; vs current run rate", "&#9660; vs current run rate")
			RETURN
			"<div style='background:#ffffff;border-radius:6px;padding:12px 14px;font-family:sans-serif'>" &
			"<div style='font-size:10px;letter-spacing:0.05em;color:#8a8a82;text-transform:uppercase'>4-week forecast</div>" &
			"<div style='font-size:22px;font-weight:600;color:#1a1a1a;margin-top:4px'>" & FORMAT(Trends, "+0.0%;-0.0%") & "</div>" &
			"<div style='display:inline-block;margin-top:6px;font-size:10px;color:" & BadgeColor & ";background:" & BadgeBg & ";padding:2px 7px;border-radius:4px'>" & BadgeText & "</div>" &
			"</div>"
		lineageTag: 5c09ad78-785b-4793-b359-461409d57abf

	partition _Measures = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", type text}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type",{"Column1"})
				in
				    #"Removed Columns"

	changedProperty = Name

	annotation PBI_ResultType = Table

